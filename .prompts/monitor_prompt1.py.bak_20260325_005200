def log_audit(message: str) -> None:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    entry = f"[{ts}] [AUDIT-PLAN] {message}"
    print(entry)
    try:
        AUDIT_LOG.parent.mkdir(parents=True, exist_ok=True)
        with AUDIT_LOG.open("a", encoding="utf-8") as f:
            f.write(entry + "\n")
    except Exception:
        pass


def count_audit_items() -> dict:
    """Cuenta total de items de auditoría por fase."""
    counts = {"frontend": 0, "backend": 0, "planes": 0, "ia_ux": 0, "legal": 0, "p0": len(HALLAZGOS_P0)}

    for section in FASE_1_FRONTEND.values():
        if isinstance(section, dict) and "vistas" in section:
            for vista in section["vistas"].values():
                if isinstance(vista, dict) and "auditar" in vista:
                    counts["frontend"] += len(vista["auditar"])

    for section in FASE_2_BACKEND.values():
        if isinstance(section, dict) and "auditar" in section:
            counts["backend"] += len(section["auditar"])

    for section in FASE_3_SUSCRIPCIONES.values():
        if isinstance(section, dict):
            if "auditar" in section:
                counts["planes"] += len(section["auditar"])
            if "hallazgos" in section:
                counts["planes"] += len(section["hallazgos"])

    counts["ia_ux"] = len(FASE_4_IA_UX.get("auditar", []))
    counts["legal"] = len(FASE_5_COMPLIANCE.get("auditar", []))
    counts["total"] = sum(counts.values())
    return counts


def generate_report() -> str:
    """Genera reporte Markdown del plan de auditoría."""
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    counts = count_audit_items()

    lines = [
        f"# OKLA — Plan de Auditoría Integral",
        f"**Generado:** {ts}",
        f"**URL:** {PRODUCTION_URL}",
        f"**Total items de auditoría:** {counts['total']}",
        "",
        "## Resumen por Fase",
        f"| Fase | Items |",
        f"|------|-------|",
        f"| FASE 1: Frontend (todas las vistas) | {counts['frontend']} |",
        f"| FASE 2: Backend (APIs, seguridad) | {counts['backend']} |",
        f"| FASE 3: Planes de Suscripción | {counts['planes']} |",
        f"| FASE 4: IA/Chatbots + UX | {counts['ia_ux']} |",
        f"| FASE 5: Compliance Legal RD | {counts['legal']} |",
        f"| Hallazgos P0 (Críticos) | {counts['p0']} |",
        "",
        "## Cuentas de Prueba",
        "| Rol | Username | Tipo |",
        "|-----|----------|------|",
    ]
    for role, acc in ACCOUNTS.items():
        lines.append(f"| {role.title()} | {acc['username']} | {acc['role']} |")

    # P0 Hallazgos
    lines.extend([
        "",
        "## HALLAZGOS P0 — Requieren acción inmediata",
        "",
    ])
    for h in HALLAZGOS_P0:
        lines.append(f"### {h['id']}: {h['titulo']}")
        lines.append(f"- **Severidad:** {h['severidad']}")
        lines.append(f"- **Área:** {h['area']}")
        lines.append(f"- **Impacto:** {h['impacto_negocio']}")
        lines.append("")

    # Desalineación de planes
    lines.extend([
        "## FASE 3A — Desalineación Planes (Detalle)",
        "",
    ])
    for h in FASE_3_SUSCRIPCIONES["3A_DESALINEACION"]["hallazgos"]:
        lines.append(f"### {h['id']}: {h['titulo']}")
        lines.append(f"- **Detalle:** {h['detalle']}")
        lines.append(f"- **Impacto:** {h['impacto']}")
        lines.append(f"- **Acción:** {h['accion']}")
        lines.append("")

    return "\n".join(lines)


def delegate_to_openclaw(tasks: list[str]) -> None:
    """Escribe tareas en prompt_1.md para que OpenClaw las ejecute."""
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    content = PROMPT_FILE.read_text(encoding="utf-8") if PROMPT_FILE.exists() else ""

    new_tasks = f"\n\n## TAREAS PENDIENTES — Auditoría Integral ({ts})\n\n"
    for task in tasks:
        new_tasks += f"- [ ] {task}\n"

    PROMPT_FILE.write_text(content + new_tasks, encoding="utf-8")
    log_audit(f"Delegated {len(tasks)} tasks to OpenClaw via prompt_1.md")


def main():
    parser = argparse.ArgumentParser(description="OKLA Comprehensive Audit Plan")
    parser.add_argument("--fase", type=int, choices=[1, 2, 3, 4, 5], help="Run specific phase only")
    parser.add_argument("--rol", choices=["guest", "buyer", "seller", "dealer", "admin"], help="Audit specific role")
    parser.add_argument("--report", action="store_true", help="Generate Markdown report")
    parser.add_argument("--delegate-openclaw", action="store_true", help="Delegate P0 tasks to OpenClaw")
    parser.add_argument("--json", action="store_true", help="Output audit plan as JSON")
    args = parser.parse_args()

    counts = count_audit_items()
    log_audit(f"Plan de auditoría cargado: {counts['total']} items totales")
    log_audit(f"  Frontend: {counts['frontend']} | Backend: {counts['backend']} | "
              f"Planes: {counts['planes']} | IA/UX: {counts['ia_ux']} | Legal: {counts['legal']}")
    log_audit(f"  Hallazgos P0 (críticos): {counts['p0']}")

    if args.json:
        plan = {
            "fase_1_frontend": FASE_1_FRONTEND,
            "fase_2_backend": FASE_2_BACKEND,
            "fase_3_suscripciones": FASE_3_SUSCRIPCIONES,
            "fase_4_ia_ux": FASE_4_IA_UX,
            "fase_5_compliance": FASE_5_COMPLIANCE,
            "hallazgos_p0": HALLAZGOS_P0,
            "cuentas": {k: {"username": v["username"], "role": v["role"]} for k, v in ACCOUNTS.items()},
            "counts": counts,
        }
        print(json.dumps(plan, indent=2, ensure_ascii=False))
        return

    if args.report:
        report = generate_report()
        REPORT_DIR.mkdir(parents=True, exist_ok=True)
        report_file = REPORT_DIR / f"audit-plan-{datetime.now().strftime('%Y%m%d_%H%M%S')}.md"
        report_file.write_text(report, encoding="utf-8")
        log_audit(f"Report generated: {report_file}")
        print(report)
        return

    if args.delegate_openclaw:
        p0_tasks = [
            f"AUDITAR EN PRODUCCIÓN: {h['titulo']} — {h['impacto_negocio']}" for h in HALLAZGOS_P0
        ]
        delegate_to_openclaw(p0_tasks)
        return

    # Default: print summary
    print("=" * 80)
    print("OKLA — PLAN DE AUDITORÍA INTEGRAL")
    print(f"URL: {PRODUCTION_URL}")
    print(f"Fecha: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print("=" * 80)
    print()

    print("📊 RESUMEN")
    print(f"  Total items: {counts['total']}")
    for k, v in counts.items():
        if k != "total":
            print(f"  {k.upper()}: {v}")
    print()

    print("🔴 HALLAZGOS P0 (ACCIÓN INMEDIATA)")
    for h in HALLAZGOS_P0:
        print(f"  [{h['severidad']}] {h['id']}: {h['titulo']}")
        print(f"    → {h['impacto_negocio']}")
    print()

    print("📋 Para ejecutar:")
    print("  python3 .prompts/monitor_prompt1.py --report        # Generar reporte MD")
    print("  python3 .prompts/monitor_prompt1.py --json          # Exportar como JSON")
    print("  python3 .prompts/monitor_prompt1.py --delegate-openclaw  # Delegar P0 a OpenClaw")
    print()


if __name__ == "__main__":
    main()
