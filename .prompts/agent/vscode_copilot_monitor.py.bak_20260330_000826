def cmd_status() -> None:
    state    = load_state()
    log_path = find_copilot_log()
    now      = time.time()
    catalog  = load_model_catalog()
    pool     = get_model_pool()
    print("\n=== OKLA WATCHDOG Monitor v6 — Estado ===")
    print(f"  Log activo      : {log_path or 'NO ENCONTRADO'}")
    if log_path:
        size = log_path.stat().st_size
        print(f"  Tamaño log      : {size:,} bytes")
        print(f"  Offset guardado : {state.get('log_offset', 0):,} bytes")
        print(f"  Pendientes      : {max(0, size - state.get('log_offset', 0)):,} bytes")
    print(f"  Último evento   : {state.get('last_event_type', 'N/A')}")
    last_ts = state.get("last_event_ts", 0)
    if last_ts:
        print(f"  Hace            : {now - last_ts:.0f}s")
    last_act = state.get("last_activity_ts", 0)
    if last_act:
        print(f"  Última actividad: hace {now - last_act:.0f}s")
    print(f"  Rate limits     : {state.get('rate_limit_count', 0)}")
    print(f"  Nuevos chats    : {state.get('new_chat_count', 0)}")
    print(f"  Continuar sent  : {state.get('continue_count', 0)}")
    # CDP indicator
    cdp_ok = is_cdp_available()
    print(f"  CDP disponible  : {cdp_ok}")
    print(f"  CDP activo      : {state.get('cdp_active', False)}")
    print(f"  Chat hash       : {state.get('chat_hash', 'N/A')[:12]}...")
    print(f"  Chat length     : {state.get('chat_len', 0)} chars")
    # Model info
    current_label = get_current_model_label()
    current_model = _slugify_model_label(current_label) or get_current_model()
    pool_idx = next((i for i, m in enumerate(pool) if m == current_model), -1)
    print(f"  Modelo UI       : {current_label or 'N/A'}")
    print(f"  Modelo settings : {get_current_model() or 'N/A'}")
    print(f"  Pool posición   : {pool_idx}/{len(pool) - 1}" if pool and pool_idx >= 0 else f"  Pool posición   : fuera de pool")
    print(f"  Pool modelos    : {', '.join(pool) if pool else 'N/A'}")
    if catalog.get("models"):
        print(f"  Catálogo UI     : {len(catalog['models'])} modelos")
        print(f"  Preferido       : {catalog.get('preferred_model_id') or 'N/A'}")
        print(f"  Grupos          : 1x={len(catalog.get('groups', {}).get('1x', []))}, 3x={len(catalog.get('groups', {}).get('3x', []))}, unknown={len(catalog.get('groups', {}).get('unknown', []))}")

    rl_ts = state.get("last_rate_limit_ts", 0)
    if rl_ts:
        elapsed   = now - rl_ts
        remaining = max(0.0, RATE_LIMIT_WAIT - elapsed)
        if remaining > 0:
            print(f"  Cooldown RL     : {remaining:.0f}s restantes")
        else:
            print(f"  Cooldown RL     : LIBRE (último hace {elapsed:.0f}s)")
    print()


