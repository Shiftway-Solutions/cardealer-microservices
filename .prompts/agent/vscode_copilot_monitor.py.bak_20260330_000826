    parser.add_argument("--screenshot",      action="store_true",
                        help="Guardar screenshot actual del workbench del chat via CDP")
    # ── New advanced UI controls ──────────────────────────────────────────────
    parser.add_argument("--scan-ui",              action="store_true",
                        help="Inventariar TODOS los componentes UI del chat (header, input, modelo, historial, etc.)")
    parser.add_argument("--discover-models-te",   action="store_true",
                        help="Descubrir modelos incluyendo submenús de thinking effort (> arrow)")
    parser.add_argument("--set-model-te",         type=str, default=None,
                        help="Cambiar modelo con thinking effort (ej: 'gpt-5.4 --thinking-effort Xhigh')")
    parser.add_argument("--thinking-effort",      type=str, default=None,
                        help="Nivel de thinking effort para --set-model-te: Low|Medium|High|Xhigh")
    parser.add_argument("--new-chat-options",     action="store_true",
                        help="Mostrar todas las opciones del dropdown +v del chat header")
    parser.add_argument("--open-chat-option",     type=str, default=None,
                        help="Abrir opción específica del dropdown: 'New Chat'|'New Chat Editor'|'New Chat Window'|'New Codex Agent'|'New Copilot CLI Session'")
    parser.add_argument("--chat-title",           action="store_true",
                        help="Mostrar el título del chat activo actual")
    parser.add_argument("--chat-history",         action="store_true",
                        help="Listar todas las conversaciones del historial de chats")
    parser.add_argument("--navigate-chat",        type=str, default=None,
                        help="Navegar a una conversación por su título (parcial, case-insensitive)")
    parser.add_argument("--stop",                 action="store_true",
                        help="Detener respuesta en curso (click en botón Stop) y salir")
    parser.add_argument("--is-generating",        action="store_true",
                        help="Verificar si el modelo está generando una respuesta ahora mismo")
    args = parser.parse_args()

    DEBUG = args.debug

    if args.status:
        cmd_status()
        return

    if args.inspect_dom:
        print(json.dumps(inspect_chat_dom(), indent=2, ensure_ascii=False))
        return

    if args.inspect_model_picker:
        print(json.dumps(inspect_model_picker(), indent=2, ensure_ascii=False))
        return

    if args.discover_models:
        print(json.dumps(discover_available_models(), indent=2, ensure_ascii=False))
        return

    if args.prefer_model:
        preferred = ensure_preferred_model()
        print(f"Modelo preferido: {preferred or 'NO DISPONIBLE'}")
        return

    if args.screenshot:
        path = capture_workbench_screenshot("manual")
        print(path or "SCREENSHOT_FAILED")
        return

    if args.action_continue:
        log("Enviando 'continuar' manualmente...", "ACTION")
        vscode_send_continue()
        return

    if args.action_new_chat:
        log("Abriendo nuevo chat + loop prompt manualmente...", "ACTION")
        vscode_open_new_chat()
        time.sleep(1.5)
        send_loop_prompt()
        return

    if args.stop_and_new_chat:
        log("Stop + nuevo chat + loop prompt manualmente...", "ACTION")
        open_new_chat_with_stop()
        return

    if args.open_chat:
        log("Abriendo nuevo chat en blanco...", "ACTION")
        vscode_open_new_chat()
        print("Nuevo chat abierto — verifica el modelo en el selector del panel")
        return

    # ── New advanced UI controls ──────────────────────────────────────────────

    if args.scan_ui:
        inventory = scan_full_ui_inventory()
        print(json.dumps(inventory, indent=2, ensure_ascii=False))
        return

    if args.discover_models_te:
        result = discover_models_with_thinking_effort()
        print(json.dumps(result, indent=2, ensure_ascii=False))
        return

    if args.set_model_te:
        ok = set_model_with_thinking_effort(args.set_model_te, args.thinking_effort)
        print(f"Modelo: {'OK' if ok else 'FALLO'} → {args.set_model_te}" +
              (f" (thinking_effort: {args.thinking_effort})" if args.thinking_effort else ""))
        return

    if args.new_chat_options:
        options = get_new_chat_options()
        print(json.dumps(options, indent=2, ensure_ascii=False))
        return

    if args.open_chat_option:
        ok = open_new_chat_option(args.open_chat_option)
        print(f"Opción '{args.open_chat_option}': {'OK' if ok else 'FALLO'}")
        return

    if args.chat_title:
        title = get_current_chat_title()
        print(f"Título del chat activo: {title or '(no detectado)'}")
        return

    if args.chat_history:
        history = get_chat_history()
        print(json.dumps(history, indent=2, ensure_ascii=False))
        return

    if args.navigate_chat:
        ok = navigate_to_chat_by_title(args.navigate_chat)
        print(f"Navegación a '{args.navigate_chat}': {'OK' if ok else 'FALLO'}")
        return

    if args.stop:
        log("Deteniendo respuesta actual...", "ACTION")
        ok = stop_current_response()
        print(f"Stop: {'OK' if ok else 'FALLO (modelo puede no estar generando)'}")
        return

    if args.is_generating:
        generating = is_response_generating()
        print(f"Generando: {generating}")
        return

    if args.show_model:
        label = get_current_model_label()
        model = _slugify_model_label(label) or get_current_model()
        pool = get_model_pool()
        pool_idx = next((i for i, m in enumerate(pool) if m == model), -1)
        print(f"Modelo activo: {label or model or 'N/A'} (pool idx: {pool_idx})")
        return

    if args.set_model:
        old = get_current_model()
        if set_model(args.set_model):
            print(f"Modelo: {old} → {args.set_model}")
        else:
            print("Error cambiando modelo")
        return

    if args.cycle_model:
        state = load_state()
        old = get_current_model()
        new = cycle_model(state, direction=1)
        save_state(state)
        print(f"Modelo ciclado: {old} → {new}")
        return

    # Inicializar estado
    state = load_state()
    if not state:
        state    = default_state()
        log_path = find_copilot_log()
        if log_path:
            state["log_path"]   = str(log_path)
            # Primera ejecución: saltar historial para no re-procesar el log completo
            state["log_offset"] = log_path.stat().st_size
            log(
                f"Primera ejecución — iniciando desde el final del log "
                f"({state['log_offset']:,} bytes): {log_path}"
            )
        save_state(state)

    # ── RESET DE ARRANQUE ─────────────────────────────────────────────────────
    # Al arrancar (sea primera vez o reinicio), el timer de inactividad siempre
    # comienza desde AHORA. Esto evita que un last_activity_ts viejo de la sesión
    # anterior haga que _stall_ok() devuelva True en el primer ciclo y dispare
    # un comando de inmediato sin haber monitoreado nada.
    startup_now = time.time()
    state["last_activity_ts"] = startup_now
    # Sincronizar last_snapshot_mtime con el mtime real actual del archivo,
    # para que el primer ciclo no lo detecte como "nuevo" y resetee el timer.
    try:
        if CHAT_SNAPSHOT_FILE.exists():
            state["last_snapshot_mtime"] = CHAT_SNAPSHOT_FILE.stat().st_mtime
    except Exception:
        pass
    # Limpiar timers de detección que podrían dispararse con estado viejo
    state["model_completion_seen_ts"] = 0.0
    state["pending_snapshot_error"]   = ""
    state["pending_snapshot_error_ts"] = 0.0
    # Limpiar estado de verificación post-acción (nueva sesión no hereda reintentos)
    state["post_action_ts"]          = 0.0
    state["post_action_type"]        = ""
    state["post_action_retry_count"] = 0
    log(
        f"Arranque fresco — timer de inactividad reseteado a 0s. "
        f"Primera acción posible en {STALL_CONTINUE_SECS // 60} min sin actividad."
    )
    save_state(state)

    log(
        f"Monitor v7 iniciado — intervalo: {args.interval}s "
        f"| inactividad_snapshot: {STALL_CONTINUE_SECS}s (15 min → nuevo chat) "
        f"| fuente_primaria: chat_snapshot.txt"
    )

    def one_cycle() -> None:
        nonlocal state
        state = run_cycle(state)
        save_state(state)

    if args.once:
        one_cycle()
        return

    # Singleton: no arrancar si ya hay un daemon corriendo
    if PID_FILE.exists():
        try:
            existing_pid = int(PID_FILE.read_text().strip())
            if existing_pid != os.getpid():
                import signal as _sig
                os.kill(existing_pid, 0)  # lanza excepcion si no existe
                log(f"Ya hay un monitor corriendo (PID {existing_pid}). Saliendo.", "WARN")
                sys.exit(0)
        except (ValueError, ProcessLookupError, PermissionError):
            pass  # PID stale — continuar

    PID_FILE.write_text(str(os.getpid()))

    # Loop principal
    while True:
        try:
            one_cycle()
        except KeyboardInterrupt:
            log("Monitor detenido por usuario (Ctrl+C)")
            sys.exit(0)
        except Exception as e:
            log(f"Error inesperado en ciclo: {e}", "ERROR")
        time.sleep(args.interval)


if __name__ == "__main__":
    main()


