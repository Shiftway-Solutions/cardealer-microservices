def read_chat_via_cdp() -> str | None:
    """
    Lee el texto visible del panel de Copilot Chat via CDP + Playwright.
    Retorna el texto o None si falla.
    """
    try:
        from playwright.sync_api import sync_playwright
    except ImportError:
        if DEBUG:
            log("Playwright no instalado — CDP deshabilitado", "DEBUG")
        return None

    try:
        with sync_playwright() as p:
            browser = p.chromium.connect_over_cdp(f"http://{CDP_HOST}:{CDP_PORT}")
            contexts = browser.contexts
            if not contexts:
                browser.close()
                return None

            # Find the main workbench page
            found_page = None
            for ctx in contexts:
                for page in ctx.pages:
                    page_url = page.url
                    if any(kw in page_url for kw in ["workbench", "copilot", "chat"]):
                        found_page = page
                        break
                if found_page:
                    break

            if not found_page and contexts and contexts[0].pages:
                found_page = contexts[0].pages[0]

            if not found_page:
                browser.close()
                return None

            # Extract chat text with multiple selectors
            selectors = [
                ".value .rendered-markdown",
                ".chat-request-part",
                "[id*='chat']",
                ".interactive-item-container",
                ".chat-list-item",
            ]

            all_texts = []
            for sel in selectors:
                try:
                    elements = found_page.query_selector_all(sel)
                    for el in elements:
                        txt = el.inner_text().strip()
                        if txt:
                            all_texts.append(txt)
                except Exception:
                    pass

            browser.close()
            return "\n".join(all_texts) if all_texts else None
    except Exception as e:
        if DEBUG:
            log(f"CDP read failed: {e}", "DEBUG")
        return None


def _text_hash(text: str) -> str:
    """Deterministic hash for change detection."""
    return hashlib.md5(text.encode("utf-8")).hexdigest()


def _body_hash(snapshot_content: str) -> str:
    """
    Hash of the snapshot body, excluding:
      - Line 1: the timestamp header ("# Chat Snapshot — 2026-03-29 10:27:06")
      - Standalone percentage lines (e.g., "14%") — active-generation indicators

    Used to distinguish MEANINGFUL chat content changes from cosmetic UI updates
    (header timestamp always changes on every write; % fluctuates while streaming).
    """
    lines = snapshot_content.splitlines()
    body = [
        l for l in (lines[1:] if lines else [])
        if not re.match(r"^\s*\d+%\s*$", l)
    ]
    return hashlib.md5("\n".join(body).encode("utf-8")).hexdigest()


# Patrones de error visibles en el texto del chat UI
CHAT_ERROR_PATTERNS = [
    (re.compile(r"rate.limit|429|Too Many Requests|quota.*exhaust", re.I), "rate_limited"),
    (re.compile(r"overloaded|503|502|500|Internal Server Error|capacity", re.I), "hard_error"),
    (re.compile(r"cancelled|canceled", re.I), "cancelled"),
]


def classify_chat_text(current_text: str, prev_hash: str) -> tuple[str, bool]:
    """
    Clasifica la actividad del chat basado en el texto visible.
    Retorna (event_type, has_changed).
    """
    current_hash = _text_hash(current_text)
    has_changed = current_hash != prev_hash

    # Check for error patterns in the latest text (last 500 chars)
    tail = current_text[-500:] if len(current_text) > 500 else current_text
    for pattern, event_type in CHAT_ERROR_PATTERNS:
        if pattern.search(tail):
            return event_type, has_changed

    if has_changed:
        return "success", True
    else:
        return "unknown", False


