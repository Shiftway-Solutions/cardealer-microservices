# ─── Full UI Component Scanner ───────────────────────────────────────────────

async def _cdp_scan_full_ui(page) -> dict:
    """Scans ALL visible UI components of VS Code Copilot Chat."""
    result: dict = {}

    # 1. Chat header actions (top bar: +v, settings, etc.)
    header_items = await page.evaluate(r"""() => {
        const items = [];
        const seen = new Set();
        for (const sel of [
            '.actions-container a[role="button"]',
            '.actions-container button',
            '.panel .action-item a[role="button"]',
        ]) {
            for (const el of document.querySelectorAll(sel)) {
                const rect = el.getBoundingClientRect();
                if (rect.width === 0 || rect.y < 30 || rect.y > 130) continue;
                const label = (el.getAttribute('aria-label') || el.innerText || '').replace(/\s+/g, ' ').trim();
                const key = label + '|' + Math.round(rect.x);
                if (seen.has(key)) continue;
                seen.add(key);
                items.push({
                    tag: el.tagName.toLowerCase(),
                    label,
                    className: (el.className || '').substring(0, 80),
                    ariaHaspopup: el.getAttribute('aria-haspopup') || '',
                    x: rect.x + rect.width / 2,
                    y: rect.y + rect.height / 2,
                    width: rect.width,
                    height: rect.height,
                });
            }
        }
        return items;
    }""")
    result['header_actions'] = header_items

    # 2. Current chat title
    chat_title = await page.evaluate(r"""() => {
        const titleSels = [
            '.pane-header .title-label h2',
            '.pane-header .title-label',
            '.panel-pane .title-label h2',
            '.panel-pane .title-label',
            '[id*="chat"] .title-label',
            '.composite.panel .title-label h2',
            '.chat-view .title-label',
        ];
        for (const sel of titleSels) {
            const el = document.querySelector(sel);
            if (el) {
                const text = (el.innerText || el.textContent || '').trim();
                if (text) return { text, selector: sel };
            }
        }
        const header = document.querySelector('.pane-header');
        if (header) {
            const text = (header.innerText || '').split('\n')[0].trim();
            if (text) return { text, selector: '.pane-header (first line)' };
        }
        return null;
    }""")
    result['current_chat_title'] = chat_title

    # 3. Model picker button (bottom of chat input)
    model_picker = await page.evaluate(r"""() => {
        const sels = [
            '.action-item.chat-input-picker-item:not(.chat-mode-picker-item):not(.chat-session-target-picker-item)',
            'a[aria-label^="Pick Model"]',
            '.chat-input-picker-item a[role="button"]',
        ];
        for (const sel of sels) {
            const el = document.querySelector(sel);
            if (!el) continue;
            const rect = el.getBoundingClientRect();
            if (rect.width === 0) continue;
            return {
                label: (el.getAttribute('aria-label') || el.innerText || '').trim(),
                className: (el.className || '').substring(0, 80),
                selector: sel,
                x: rect.x + rect.width / 2,
                y: rect.y + rect.height / 2,
            };
        }
        return null;
    }""")
    result['model_picker_btn'] = model_picker

    # 4. Chat input area
    chat_input = await page.evaluate(r"""() => {
        const inputSels = [
            '.interactive-input-part .monaco-editor',
            '.chat-input-container .monaco-editor',
            '.chat-widget textarea',
            '.interactive-input-box textarea',
            '[aria-label*="Ask Copilot" i]',
            '[placeholder*="Ask Copilot" i]',
        ];
        for (const sel of inputSels) {
            const el = document.querySelector(sel);
            if (!el) continue;
            const rect = el.getBoundingClientRect();
            if (rect.width === 0) continue;
            return {
                tag: el.tagName.toLowerCase(),
                selector: sel,
                placeholder: el.getAttribute('placeholder') || '',
                ariaLabel: el.getAttribute('aria-label') || '',
                className: (el.className || '').substring(0, 80),
                x: rect.x + rect.width / 2,
                y: rect.y + rect.height / 2,
            };
        }
        return null;
    }""")
    result['chat_input'] = chat_input

    # 5. Stop response button (only visible when generating)
    stop_btn = await page.evaluate(r"""() => {
        const stopSels = [
            'button[aria-label="Stop Response"]',
            'button[aria-label*="Stop" i]',
            '.interactive-stop-button',
            '.chat-stop-button',
            '[class*="codicon-debug-stop"]',
            '[class*="codicon-stop-circle"]',
            'button[title*="Stop" i]',
            'a[aria-label*="Stop" i]',
        ];
        for (const sel of stopSels) {
            const el = document.querySelector(sel);
            if (!el) continue;
            const rect = el.getBoundingClientRect();
            if (rect.width === 0) continue;
            return {
                selector: sel,
                label: (el.getAttribute('aria-label') || el.getAttribute('title') || '').trim(),
                visible: true,
                x: rect.x + rect.width / 2,
                y: rect.y + rect.height / 2,
            };
        }
        return { visible: false };
    }""")
    result['stop_btn'] = stop_btn

    # 6. Send button
    send_btn = await page.evaluate(r"""() => {
        const sendSels = [
            'button[aria-label*="Send" i]',
            '.interactive-execute-toolbar .action-item a[role="button"]',
            '.chat-execute-button',
            '[class*="codicon-send"]',
        ];
        for (const sel of sendSels) {
            const el = document.querySelector(sel);
            if (!el) continue;
            const rect = el.getBoundingClientRect();
            if (rect.width === 0) continue;
            return {
                selector: sel,
                label: (el.getAttribute('aria-label') || '').trim(),
                x: rect.x + rect.width / 2,
                y: rect.y + rect.height / 2,
            };
        }
        return null;
    }""")
    result['send_btn'] = send_btn

    # 7. Input toolbar (mode picker, attach, etc.)
    input_toolbar = await page.evaluate(r"""() => {
        const items = [];
        for (const el of document.querySelectorAll(
            '.interactive-input-part .action-item a[role="button"], .chat-input-part .action-item a[role="button"]'
        )) {
            const rect = el.getBoundingClientRect();
            if (rect.width === 0) continue;
            items.push({
                label: (el.getAttribute('aria-label') || el.innerText || '').replace(/\s+/g, ' ').trim(),
                className: (el.className || '').substring(0, 60),
                x: rect.x + rect.width / 2,
                y: rect.y + rect.height / 2,
            });
        }
        return items;
    }""")
    result['input_toolbar'] = input_toolbar

    # 8. Chat history entries
    history_items = await page.evaluate(r"""() => {
        const sels = [
            '.chat-list-view .monaco-list-row',
            '[aria-label*="chat history" i] .monaco-list-row',
            '.chat-history-list .monaco-list-row',
            '.pane-body .monaco-list-row',
        ];
        for (const sel of sels) {
            const els = [...document.querySelectorAll(sel)];
            if (!els.length) continue;
            return els.slice(0, 30).map((el) => {
                const rect = el.getBoundingClientRect();
                return {
                    text: (el.innerText || '').replace(/\s+/g, ' ').trim(),
                    ariaLabel: (el.getAttribute('aria-label') || '').trim(),
                    ariaSelected: el.getAttribute('aria-selected') || '',
                    dataIndex: el.getAttribute('data-index') || '',
                    x: rect.x + rect.width / 2,
                    y: rect.y + rect.height / 2,
                };
            });
        }
        return [];
    }""")
    result['chat_history'] = history_items

    return result


def scan_full_ui_inventory() -> dict:
    """
    Scans ALL visible UI components of the VS Code Copilot Chat panel.
    Returns inventory: header_actions, model_picker_btn, chat_input,
    stop_btn, send_btn, input_toolbar, chat_history, current_chat_title.
    """
    if not is_cdp_available():
        return {"error": "cdp_unavailable"}

    try:
        vscode_focus()
        time.sleep(0.5)
        import asyncio as _asyncio

        async def _do_scan():
            playwright, browser, page = await _cdp_connect_workbench_page()
            try:
                if not page:
                    return {"error": "workbench_not_found"}
                screenshot = await _cdp_capture_screenshot(page, "ui-inventory")
                result = await _cdp_scan_full_ui(page)
                result["screenshot"] = screenshot
                result["captured_at"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                return result
            finally:
                await _cdp_close(playwright, browser)

        return _asyncio.run(_do_scan())
    except Exception as e:
        log(f"UI inventory error: {e}", "WARN")
        return {"error": str(e)}


# ─── Model Picker: Full Traversal Including Thinking Effort Submenus ──────────

async def _cdp_traverse_all_model_submenus(page) -> dict:
    """
    Opens the model picker and traverses ALL submenus:
      - Root models (with and without thinking effort)
      - "Other Models" submenu
      - Per-model thinking effort submenus (items with > chevron arrow)

    Returns {
        "root": [str, ...],
        "other_models": [str, ...],
        "thinking_effort": {"ModelName": ["Low", "Medium(default)", "High", "Xhigh"], ...},
        "items_with_arrows": [{"text": ..., "hasArrow": bool}, ...]
    }
    """
    import asyncio

    result: dict = {"root": [], "other_models": [], "thinking_effort": {}, "items_with_arrows": []}

    if not await _cdp_open_model_picker(page):
        return result

    await asyncio.sleep(0.6)
    await _cdp_capture_screenshot(page, "traverse-submenus_root")

    root_items = await _cdp_collect_overlay_items(page)
    for item in root_items:
        item_text = (item.get("text") or "").strip()
        if item_text and _looks_like_model_option(item_text):
            result["root"].append(item_text)

    # Detect items with submenu arrows
    items_with_arrows = await page.evaluate(r"""() => {
        const rows = [...document.querySelectorAll(
            '.context-view .monaco-list-row, .context-view [role="menuitem"], .context-view [role="menuitemradio"]'
        )];
        return rows
            .filter((row) => row.getBoundingClientRect().width > 0)
            .map((row) => {
                const rect = row.getBoundingClientRect();
                const hasArrow = !!(row.querySelector(
                    '.submenu-indicator, .codicon-chevron-right, [class*="chevron-right"], [class*="submenu"]'
                ));
                const checked = row.getAttribute('aria-checked') || '';
                return {
                    text: (row.innerText || '').replace(/\s+/g, ' ').trim(),
                    hasArrow,
                    checked,
                    x: rect.x + rect.width / 2,
                    y: rect.y + rect.height / 2,
                    width: rect.width,
                    height: rect.height,
                };
            })
            .filter((r) => r.text);
    }""")
    result["items_with_arrows"] = items_with_arrows

    root_texts = {(r.get("text") or "").strip() for r in root_items}

    for trigger in items_with_arrows:
        text = trigger.get("text", "")
        if not trigger.get("hasArrow"):
            continue

        is_other_models = any(kw in text.lower() for kw in ("other models", "more models", "browse models"))

        await page.mouse.move(trigger["x"], trigger["y"])
        await asyncio.sleep(0.7)
        label_for_screenshot = text[:20].replace(" ", "_")
        await _cdp_capture_screenshot(page, f"traverse-submenus_{label_for_screenshot}")

        nested = await page.evaluate(r"""() => {
            const rows = [...document.querySelectorAll('.context-view .monaco-list-row')];
            return rows.filter((r) => r.getBoundingClientRect().width > 0).map((r) => {
                const rect = r.getBoundingClientRect();
                return {
                    text: (r.innerText || '').replace(/\s+/g, ' ').trim(),
                    checked: r.getAttribute('aria-checked') || '',
                    x: rect.x + rect.width / 2,
                    y: rect.y + rect.height / 2,
                };
            }).filter((r) => r.text);
        }""")
        new_items = [n for n in nested if n["text"] and n["text"] not in root_texts]

        if is_other_models:
            result["other_models"].extend(n["text"] for n in new_items)
        elif new_items:
            result["thinking_effort"][text] = [n["text"] for n in new_items]

    # Close picker
    await page.keyboard.press("Escape")
    await asyncio.sleep(0.2)
    return result


def discover_models_with_thinking_effort() -> dict:
    """
    Discovers ALL models including per-model thinking effort submenus (> arrow).
    Returns {
        "root": [str, ...],
        "other_models": [str, ...],
        "thinking_effort": {"ModelName": ["Low", "Medium(default)", "High", "Xhigh"], ...},
        "catalog": {...},
        "captured_at": "..."
    }
    """
    if not is_cdp_available():
        return {"error": "cdp_unavailable"}

    try:
        vscode_focus()
        time.sleep(0.5)
        import asyncio as _asyncio

        async def _do_discover():
            playwright, browser, page = await _cdp_connect_workbench_page()
            try:
                if not page:
                    return {"error": "workbench_not_found"}
                await _cdp_capture_screenshot(page, "discover-te_before")
                result = await _cdp_traverse_all_model_submenus(page)
                result["captured_at"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                return result
            finally:
                await _cdp_close(playwright, browser)

        data = _asyncio.run(_do_discover())
        # Also run standard catalog discovery (non-async) and merge
        catalog = discover_available_models()
        data["catalog"] = catalog
        return data
    except Exception as e:
        log(f"discover_models_with_thinking_effort error: {e}", "WARN")
        return {"error": str(e)}


def set_model_with_thinking_effort(model_text: str, thinking_effort: str | None = None) -> bool:
    """
    Selects a model AND optionally sets its thinking effort level via the > submenu.

    Args:
        model_text: Model name/slug (e.g. "gpt-5.4", "claude-sonnet-4-6")
        thinking_effort: "Low", "Medium", "High", "Xhigh" or None (keep current)

    If thinking_effort is None, delegates to existing set_model() logic.
    """
    if thinking_effort is None:
        return set_model(model_text)

    if not is_cdp_available():
        log("CDP no disponible para set thinking effort", "WARN")
        return set_model(model_text)

    try:
        vscode_focus()
        time.sleep(0.5)
        import asyncio as _asyncio

        async def _do_set_te():
            import asyncio
            playwright, browser, page = await _cdp_connect_workbench_page()
            try:
                if not page:
                    return False
                await _cdp_capture_screenshot(page, f"set-te_before")
                if not await _cdp_open_model_picker(page):
                    return False
                await asyncio.sleep(0.6)

                items_with_detail = await page.evaluate(r"""() => {
                    const rows = [...document.querySelectorAll(
                        '.context-view .monaco-list-row, .context-view [role="menuitem"], .context-view [role="menuitemradio"]'
                    )];
                    return rows
                        .filter((row) => row.getBoundingClientRect().width > 0)
                        .map((row) => {
                            const rect = row.getBoundingClientRect();
                            const hasArrow = !!(row.querySelector(
                                '.submenu-indicator, .codicon-chevron-right, [class*="chevron-right"]'
                            ));
                            return {
                                text: (row.innerText || '').replace(/\s+/g, ' ').trim(),
                                hasArrow,
                                x: rect.x + rect.width / 2,
                                y: rect.y + rect.height / 2,
                            };
                        })
                        .filter((r) => r.text);
                }""")

                model_norm = _normalize_ui_text(model_text)
                target_row = next(
                    (r for r in items_with_detail
                     if model_norm in _normalize_ui_text(r.get("text", ""))
                     or _normalize_ui_text(r.get("text", "")) in model_norm),
                    None,
                )

                if not target_row:
                    # Try "Other Models" submenu
                    other_row = next(
                        (r for r in items_with_detail if "other" in r.get("text", "").lower()),
                        None,
                    )
                    if other_row:
                        await page.mouse.move(other_row["x"], other_row["y"])
                        await asyncio.sleep(0.7)
                        nested_rows = await page.evaluate(r"""() => {
                            const rows = [...document.querySelectorAll('.context-view .monaco-list-row')];
                            return rows.filter((r) => r.getBoundingClientRect().width > 0).map((r) => {
                                const rect = r.getBoundingClientRect();
                                const hasArrow = !!(r.querySelector('.submenu-indicator, .codicon-chevron-right'));
                                return {
                                    text: (r.innerText || '').replace(/\s+/g, ' ').trim(),
                                    hasArrow,
                                    x: rect.x + rect.width / 2,
                                    y: rect.y + rect.height / 2,
                                };
                            }).filter((r) => r.text);
                        }""")
                        target_row = next(
                            (r for r in nested_rows
                             if model_norm in _normalize_ui_text(r.get("text", ""))),
                            None,
                        )

                if not target_row:
                    await page.keyboard.press("Escape")
                    log(f"Modelo '{model_text}' no encontrado en el picker", "WARN")
                    return False

                if not target_row.get("hasArrow"):
                    await page.mouse.click(target_row["x"], target_row["y"])
                    await asyncio.sleep(0.4)
                    await _cdp_capture_screenshot(page, f"set-te_after_no-arrow")
                    log(f"Modelo seleccionado: {target_row['text']} (sin thinking effort submenu)", "MODEL")
                    return True

                # Hover to open thinking effort submenu
                await page.mouse.move(target_row["x"], target_row["y"])
                await asyncio.sleep(0.7)
                await _cdp_capture_screenshot(page, f"set-te_submenu")
                te_items = await page.evaluate(r"""() => {
                    const rows = [...document.querySelectorAll('.context-view .monaco-list-row')];
                    return rows.filter((r) => r.getBoundingClientRect().width > 0).map((r) => {
                        const rect = r.getBoundingClientRect();
                        return {
                            text: (r.innerText || '').replace(/\s+/g, ' ').trim(),
                            checked: r.getAttribute('aria-checked') || '',
                            x: rect.x + rect.width / 2,
                            y: rect.y + rect.height / 2,
                        };
                    }).filter((r) => r.text);
                }""")

                te_norm = _normalize_ui_text(thinking_effort)
                te_target = next(
                    (item for item in te_items
                     if te_norm in _normalize_ui_text(item.get("text", ""))
                     or _normalize_ui_text(item.get("text", "")).startswith(te_norm)),
                    None,
                )
                if not te_target:
                    # Fallback: just click the model row itself
                    await page.mouse.click(target_row["x"], target_row["y"])
                    await asyncio.sleep(0.4)
                    log(f"thinking_effort '{thinking_effort}' no encontrado — modelo seleccionado sin TE", "WARN")
                    return True

                await page.mouse.click(te_target["x"], te_target["y"])
                await asyncio.sleep(0.4)
                await _cdp_capture_screenshot(page, f"set-te_selected")
                log(f"Modelo + thinking effort: {target_row['text']} → {te_target['text']}", "MODEL")
                return True
            finally:
                await _cdp_close(playwright, browser)

        return _asyncio.run(_do_set_te())
    except Exception as e:
        log(f"set_model_with_thinking_effort error: {e}", "WARN")
        return False


# ─── New Chat Dropdown Options (+v button) ───────────────────────────────────

async def _cdp_get_new_chat_dropdown(page) -> list:
    """
    Finds and clicks the ▼ chevron button next to the + (New Chat) button in the
    Copilot Chat auxiliarybar header, then reads all available options.

    Selector: a[aria-label="New Chat"][class*="codicon-chevron-down"][aria-haspopup="true"]
    Location: auxiliarybar header, y ≈ 52, right next to the + button.

    Typical options:
      - New Chat (⌘N)
      - New Chat Editor
      - New Chat Window
      - New Codex Agent
      - New Copilot CLI Session
    """
    import asyncio

    await _cdp_capture_screenshot(page, "new-chat-dropdown_before")

    # Precise selector: the chevron button next to + in the auxiliarybar header
    dropdown_btn = await page.evaluate(r"""() => {
        // Strategy 1: the codicon-chevron-down with aria-haspopup in auxiliarybar
        for (const el of document.querySelectorAll(
            '.auxiliarybar a[aria-haspopup="true"], .part.auxiliarybar a[aria-haspopup]'
        )) {
            const rect = el.getBoundingClientRect();
            if (rect.width === 0) continue;
            const auxBar = document.querySelector('#workbench\\.parts\\.auxiliarybar, .part.auxiliarybar');
            const auxTop = auxBar ? auxBar.getBoundingClientRect().y : 0;
            if (rect.y > auxTop + 60) continue;  // only in the top header bar
            const label = (el.getAttribute('aria-label') || '').toLowerCase();
            const cls = (el.className || '').toLowerCase();
            if (cls.includes('chevron') || label.includes('new chat')) {
                return { label: el.getAttribute('aria-label') || '', x: rect.x + rect.width / 2, y: rect.y + rect.height / 2 };
            }
        }
        // Strategy 2: any a with aria-haspopup in auxbar header area
        for (const el of document.querySelectorAll('.part.auxiliarybar a[aria-haspopup="true"]')) {
            const rect = el.getBoundingClientRect();
            if (rect.width === 0) continue;
            return { label: el.getAttribute('aria-label') || '', x: rect.x + rect.width / 2, y: rect.y + rect.height / 2 };
        }
        return null;
    }""")

    if not dropdown_btn:
        return []

    await page.mouse.click(dropdown_btn["x"], dropdown_btn["y"])
    await asyncio.sleep(0.6)
    await _cdp_capture_screenshot(page, "new-chat-dropdown_opened")

    menu_items = await page.evaluate(r"""() => {
        const results = [];
        const seen = new Set();
        for (const sel of [
            '.context-view .monaco-list-row',
            '.context-view .action-item',
            '.monaco-menu .action-item',
            '.context-menu .action-item',
        ]) {
            for (const el of document.querySelectorAll(sel)) {
                const rect = el.getBoundingClientRect();
                if (rect.width === 0) continue;
                const text = (el.innerText || el.getAttribute('aria-label') || '').replace(/\s+/g, ' ').trim();
                if (!text || text === '\u2014') continue;
                const key = text + '|' + Math.round(rect.x);
                if (seen.has(key)) continue;
                seen.add(key);
                const kb = el.querySelector('.keybinding');
                results.push({
                    text,
                    role: el.getAttribute('role') || '',
                    keybinding: kb ? (kb.innerText || '').trim() : '',
                    x: rect.x + rect.width / 2,
                    y: rect.y + rect.height / 2,
                });
            }
        }
        return results.slice(0, 20);
    }""")

    await page.keyboard.press("Escape")
    await asyncio.sleep(0.3)
    return menu_items


