def is_chat_input_focused() -> bool:
    """
    Verifica que el foco esté específicamente en el textarea del chat de Copilot.

    Estrategia dual:
      1. CDP (Playwright) — consulta document.activeElement y valida que sea
         el input del chat mediante selectores conocidos de VS Code.
      2. AppleScript fallback — consulta AXFocusedUIElement del proceso Code
         y verifica que su AXRoleDescription o AXIdentifier contenga palabras
         clave del chat ('chat', 'copilot', 'input').

    Retorna True si el foco está confirmado en el chat input, False si no.
    """
    # ─ Intento 1: CDP ─────────────────────────────────────────────────────────────────
    if is_cdp_available():
        try:
            from playwright.sync_api import sync_playwright
            with sync_playwright() as p:
                browser = p.chromium.connect_over_cdp(f"http://{CDP_HOST}:{CDP_PORT}")
                page = None
                for ctx in browser.contexts:
                    for pg in ctx.pages:
                        if "workbench" in pg.url:
                            page = pg
                            break
                    if page:
                        break
                if not page and browser.contexts and browser.contexts[0].pages:
                    page = browser.contexts[0].pages[0]

                if page:
                    focused = page.evaluate("""
                        () => {
                            const el = document.activeElement;
                            if (!el) return '';
                            const tag = el.tagName.toLowerCase();
                            const cls = (el.className || '').toLowerCase();
                            const placeholder = (el.getAttribute('placeholder') || '').toLowerCase();
                            const ariaLabel = (el.getAttribute('aria-label') || '').toLowerCase();
                            const inputContainer = document.querySelector(
                                '.chat-input-container, .interactive-input-box, .interactive-input-part, .chat-widget, [class*="chat-input"], [class*="interactive-input"]'
                            );
                            const parent = (el.closest(
                                '.chat-input-container, .interactive-input-box, .interactive-input-part, .chat-widget, [class*="chat-input"], [class*="interactive-input"]'
                            ) || el).className || '';
                            return JSON.stringify({
                                tag, cls: cls.substring(0, 80),
                                placeholder: placeholder.substring(0, 60),
                                ariaLabel: ariaLabel.substring(0, 60),
                                parent: ((inputContainer && inputContainer.className) || parent).substring(0, 120),
                                editable: el.getAttribute('contenteditable') === 'true',
                                focusWithin: !!(inputContainer && inputContainer.matches(':focus-within'))
                            });
                        }
                    """)
                    browser.close()
                    if focused:
                        import json as _json
                        info = _json.loads(focused)
                        is_input = _looks_like_chat_input_focus(info)
                        if DEBUG:
                            log(
                                f"CDP focus check: tag={info.get('tag','')} editable={info.get('editable', False)} "
                                f"cls='{str(info.get('cls',''))[:40]}' parent='{str(info.get('parent',''))[:40]}' → {is_input}",
                                "DEBUG",
                            )
                        return is_input
                else:
                    browser.close()
        except Exception as e:
            if DEBUG:
                log(f"CDP focus check error: {e}", "DEBUG")

    # ─ Intento 2: AppleScript AX ───────────────────────────────────────────────────────
    try:
        ax_info = run_applescript("""
            tell application "System Events"
                tell process "Code"
                    set focEl to focused UI element
                    set roleDesc to role description of focEl
                    set axId to value of attribute "AXIdentifier" of focEl
                    return roleDesc & "|" & axId
                end tell
            end tell
        """)
        ax_lower = ax_info.lower()
        # El input del chat tiene role 'text area' y un identifier con 'chat' o 'copilot'
        is_input = (
            ("text" in ax_lower or "edit" in ax_lower)
            and any(kw in ax_lower for kw in ("chat", "copilot", "interactive", "ask"))
        )
        if DEBUG:
            log(f"AX focus check: '{ax_info.strip()}' → {is_input}", "DEBUG")
        return is_input
    except Exception:
        # Si AX falla no podemos confirmar — asumir que sí tiene foco
        # (conservador: evitar falsos negativos que bloqueen el envío)
        return True


# ─── Snapshot abort mechanism ─────────────────────────────────────────────────
# When the monitor is sending a command (AppleScript keystrokes), if
# chat_snapshot.txt starts changing it means the agent is actively responding.
# In that case we abort the action and return to normal monitoring.
_action_baseline_mtime: float = 0.0
_action_in_progress: bool = False


def _snapshot_mtime() -> float:
    """Get current mtime of chat_snapshot.txt, or 0.0 if not found."""
    try:
        return CHAT_SNAPSHOT_FILE.stat().st_mtime if CHAT_SNAPSHOT_FILE.exists() else 0.0
    except Exception:
        return 0.0


def _begin_action() -> None:
    """Record snapshot baseline before starting an action."""
    global _action_baseline_mtime, _action_in_progress
    _action_baseline_mtime = _snapshot_mtime()
    _action_in_progress = True


def _should_abort_action() -> bool:
    """Return True if chat_snapshot.txt changed since the action began.
    This means the agent is active and we should stop sending commands."""
    if not _action_in_progress:
        return False
    current = _snapshot_mtime()
    return current > _action_baseline_mtime


def _end_action() -> None:
    """Mark action as finished."""
    global _action_in_progress
    _action_in_progress = False


def _stall_ok(state: dict, now: float) -> bool:
    """Universal gate: returns True only if chat_snapshot.txt has been inactive
    for at least STALL_CONTINUE_SECS (15 min). This is the single source of
    truth for 'can we send a command?'. Any snapshot activity resets the timer.
    """
    stall_secs = now - state.get("last_activity_ts", now)
    return stall_secs >= STALL_CONTINUE_SECS


def _stall_remaining(state: dict, now: float) -> float:
    """Returns how many seconds remain until the 15-min stall gate opens."""
    stall_secs = now - state.get("last_activity_ts", now)
    return max(0.0, STALL_CONTINUE_SECS - stall_secs)


def _mark_post_action(state: dict, action_type: str, now: float) -> None:
    """Registra que se acaba de enviar una acción (continuar / nuevo chat).
    El siguiente ciclo entrará en modo verificación durante POST_ACTION_VERIFY_SECS.
    """
    state["post_action_ts"]   = now
    state["post_action_type"] = action_type
    # NO resetear retry_count aquí — se resetea solo cuando se normaliza o se escala


def _handle_post_action_verification(state: dict, now: float) -> tuple[bool, dict]:
    """
    Maneja el ciclo de verificación post-acción (máx 2 minutos).

    Flujo determinista:
      1. Actividad detectada (last_activity_ts > post_action_ts + 5s)
         → Normalizado → limpiar estado → ciclo normal.
      2. Dentro de 2 min sin actividad
         → Seguir esperando → return (True, state).
      3. Expiró 2 min sin actividad, retry_count == 0
         → Reenviar el mismo comando → reiniciar timer → return (True, state).
      4. Expiró 2 min sin actividad, retry_count > 0
         → Escalar: abrir nuevo chat con AGENT_LOOP_PROMPT → return (True, state).

    Returns:
        (True,  state) → skip ciclo normal (en verificación)
        (False, state) → continuar con ciclo normal (normalizado o no había acción)
    """
    post_ts = state.get("post_action_ts", 0.0)
    if post_ts == 0.0:
        return False, state  # no hay acción pendiente → ciclo normal

    action_type = state.get("post_action_type", "continue")
    retry_count = state.get("post_action_retry_count", 0)
    elapsed_post = now - post_ts

    # ─── ¿Normalizado? ────────────────────────────────────────────────────────
    # Actividad nueva = last_activity_ts actualizado DESPUÉS de que se envió el cmd
    activity_after = state.get("last_activity_ts", 0.0) > (post_ts + 5.0)
    if activity_after:
        log(
            f"POST-ACCIÓN ({action_type}): normalizado en {elapsed_post:.0f}s "
            f"→ volviendo a modo monitoreo",
            "ACTION",
        )
        state["post_action_ts"]          = 0.0
        state["post_action_type"]        = ""
        state["post_action_retry_count"] = 0
        return False, state  # normalizado → continuar ciclo normal

    # ─── Dentro del plazo de 2 min ────────────────────────────────────────────
    if elapsed_post < POST_ACTION_VERIFY_SECS:
        remaining = POST_ACTION_VERIFY_SECS - elapsed_post
        log(
            f"POST-ACCIÓN ({action_type}): sin respuesta aún "
            f"({elapsed_post:.0f}s / {POST_ACTION_VERIFY_SECS}s, {remaining:.0f}s restantes para verificar)",
            "INFO",
        )
        return True, state  # seguir esperando

    # ─── 2 min expirados sin normalización ────────────────────────────────────
    if retry_count == 0:
        # Primer reintento: reenviar el mismo comando
        log(
            f"POST-ACCIÓN ({action_type}): sin normalización tras {elapsed_post:.0f}s "
            f"— reintentando mismo comando (intento 1/1)",
            "WARN",
        )
        notify("OKLA Monitor", f"Sin respuesta ({action_type}) → reintentando")
        if action_type == "continue":
            vscode_send_continue()
        else:
            # new_chat: reabrir nuevo chat respetando cooldown
            elapsed_nc = now - state.get("last_new_chat_ts", 0.0)
            if elapsed_nc >= NEW_CHAT_COOLDOWN:
                vscode_open_new_chat()
                send_loop_prompt()
                state["last_new_chat_ts"] = now
                state["new_chat_count"]   = state.get("new_chat_count", 0) + 1
            else:
                remaining_cd = NEW_CHAT_COOLDOWN - elapsed_nc
                log(f"Reintento new_chat: cooldown activo ({remaining_cd:.0f}s restantes) — esperando", "INFO")
        state["post_action_ts"]          = now  # reiniciar timer de verificación
        state["post_action_retry_count"] = retry_count + 1
        return True, state  # nueva ventana de 2 min

    else:
        # Reintento también falló → escalar: abrir nuevo chat con AGENT_LOOP_PROMPT
        log(
            f"POST-ACCIÓN ({action_type}): reintento también expiró sin normalización "
            f"— escalando a nuevo chat con AGENT_LOOP_PROMPT",
            "WARN",
        )
        notify("OKLA Monitor", "Reintento falló → escalando a nuevo chat")
        # Limpiar estado de post-acción antes de escalar
        state["post_action_ts"]          = 0.0
        state["post_action_type"]        = ""
        state["post_action_retry_count"] = 0

        elapsed_nc = now - state.get("last_new_chat_ts", 0.0)
        if elapsed_nc >= NEW_CHAT_COOLDOWN:
            old_model = get_current_model()
            new_model = cycle_model(state, direction=1)
            log(f"Escalación post-acción: modelo {old_model} → {new_model}", "ACTION")
            vscode_open_new_chat()
            send_loop_prompt()
            state["last_new_chat_ts"]     = now
            state["new_chat_count"]       = state.get("new_chat_count", 0) + 1
            state["last_activity_ts"]     = now
            state["error_continue_count"] = 0
            # Entrar en verificación para el nuevo chat abierto
            state["post_action_ts"]          = now
            state["post_action_type"]        = "new_chat"
            state["post_action_retry_count"] = 0
        else:
            remaining_cd = NEW_CHAT_COOLDOWN - elapsed_nc
            log(f"Escalación post-acción: cooldown activo ({remaining_cd:.0f}s restantes) — esperando", "INFO")

        return True, state  # continuar monitoreando


def stop_current_response() -> bool:
    """
    Hace click en el botón Stop (cuadrito) del chat si el modelo está generando.

    El botón Stop solo aparece mientras el modelo procesa una respuesta.
    Hay que detener la generación ANTES de abrir un nuevo chat para evitar
    que VS Code quede en un estado inconsistente.

    Orden de intento:
      1. CDP + Playwright — click trusted en el botón por selector CSS
      2. Fallback AppleScript — Escape (cancela en algunos contextos)

    Retorna True si el click tuvo efecto, False en caso contrario.
    """
    if is_cdp_available():
        try:
            import asyncio as _asyncio

            async def _do_stop():
                playwright, browser, page = await _cdp_connect_workbench_page()
                try:
                    if not page:
                        return False

                    await _cdp_capture_screenshot(page, "stop-before")
                    snapshot = await _cdp_collect_dom_snapshot(page)
                    candidate = _pick_best_action(
                        snapshot.get("items", []),
                        include_any=("stop response", "stop", "detener", "cancel"),
                        scopes=("chat",),
                        class_hints=("interactive-stop-button", "chat-stop-button", "codicon-debug-stop", "codicon-stop-circle"),
                    )
                    if candidate and await _cdp_click_item(page, candidate):
                        await _cdp_capture_screenshot(page, "stop-after-dom")
                        log(f"Stop button clickeado via DOM: {candidate.get('text') or candidate.get('aria')}", "ACTION")
                        return True

                    stop_selectors = [
                        'button[aria-label="Stop Response"]',
                        'button[aria-label="Stop"]',
                        '.interactive-stop-button',
                        '.chat-stop-button',
                        'button.codicon-debug-stop',
                        'button[title*="Stop" i]',
                        'a[aria-label*="Stop" i]',
                        '.monaco-button[aria-label*="Stop" i]',
                    ]
                    for selector in stop_selectors:
                        try:
                            btn = await page.query_selector(selector)
                            if not btn:
                                continue
                            box = await btn.bounding_box()
                            if not box:
                                continue
                            await page.mouse.click(box["x"] + box["width"] / 2, box["y"] + box["height"] / 2)
                            await _cdp_capture_screenshot(page, "stop-after-selector", {"selector": selector})
                            log(f"Stop button clickeado (selector fallback: {selector})", "ACTION")
                            return True
                        except Exception:
                            continue

                    return False
                finally:
                    await _cdp_close(playwright, browser)

            ok = _asyncio.run(_do_stop())
            if ok:
                time.sleep(1.0)
                return True
        except Exception as e:
            log(f"CDP stop_current_response error: {e}", "WARN")

    # Fallback: Escape via AppleScript
    log("Stop via CDP no disponible — enviando Escape via AppleScript", "WARN")
    vscode_focus()
    run_applescript("""
        tell application "System Events"
            tell process "Code"
                key code 53
                delay 0.5
            end tell
        end tell
    """)
    return False


def open_new_chat_with_stop() -> bool:
    """
    Flujo completo para cambiar de chat cuando el contexto está lleno o
    el chat se está congelando:

      1. Click en el botón Stop (cuadrito) — detiene el modelo en curso
      2. Espera 1.5s para que VS Code procese el stop
      3. Abre un nuevo chat via Command Palette
      4. Envía el contenido de AGENT_LOOP_PROMPT.md

    Si chat_snapshot.txt cambia durante la acción (agente activo), aborta.
    Retorna True si completó, False si abortó.
    """
    _begin_action()
    log("Contexto lleno / chat congelado — deteniendo respuesta y abriendo nuevo chat", "ACTION")
    notify("OKLA Monitor", "Contexto lleno → deteniendo y abriendo nuevo chat")

    # 1. Detener generación actual
    stopped = stop_current_response()
    if stopped:
        log("Respuesta detenida exitosamente antes del nuevo chat", "ACTION")
    else:
        log("Stop no tuvo efecto — puede que el modelo ya hubiera terminado", "INFO")

    if _should_abort_action():
        log("ABORT: chat_snapshot.txt cambió durante stop — agente activo, cancelando acción", "ACTION")
        _end_action()
        return False

    time.sleep(1.5)

    if _should_abort_action():
        log("ABORT: chat_snapshot.txt cambió durante espera — agente activo, cancelando acción", "ACTION")
        _end_action()
        return False

    # 2. Abrir nuevo chat
    vscode_open_new_chat()

    if _should_abort_action():
        log("ABORT: chat_snapshot.txt cambió tras abrir chat — agente activo, no enviando prompt", "ACTION")
        _end_action()
        return False

    # 3. Enviar AGENT_LOOP_PROMPT
    send_loop_prompt()

    _end_action()
    return True


async def _cdp_click_new_chat_plus_button(page) -> bool:
    """
    Clicks the + (New Chat) button directly via DOM/CDP.
    Selector: .part.auxiliarybar a[aria-label="New Chat (⌘N)"]  (no aria-haspopup)
    This is the direct-action button (not the dropdown chevron).
    Returns True if clicked successfully.
    """
    import asyncio

    btn = await page.evaluate(r"""() => {
        // The + button: aria-label="New Chat (⌘N)", class includes codicon-plus, NO aria-haspopup
        const sels = [
            '.part.auxiliarybar a[aria-label="New Chat (⌘N)"]',
            '.auxiliarybar a[aria-label="New Chat (⌘N)"]',
            '.part.auxiliarybar a[class*="codicon-plus"]:not([aria-haspopup])',
        ];
        for (const sel of sels) {
            for (const el of document.querySelectorAll(sel)) {
                const r = el.getBoundingClientRect();
                if (r.width > 0) {
                    // Confirm: no aria-haspopup (that would be the dropdown chevron)
                    if (el.getAttribute('aria-haspopup')) continue;
                    return { x: Math.round(r.x + r.width / 2), y: Math.round(r.y + r.height / 2), label: el.getAttribute('aria-label') || '' };
                }
            }
        }
        return null;
    }""")

    if not btn:
        return False

    log(f"DOM/CDP: click en botón + New Chat en ({btn['x']}, {btn['y']})", "ACTION")
    await page.mouse.click(btn["x"], btn["y"])
    await asyncio.sleep(1.0)
    return True


def vscode_open_new_chat() -> bool:
    """
    Abre un nuevo chat de Copilot.

    Estrategia (en orden):
      1. DOM/CDP directo: click en el botón + a[aria-label="New Chat (⌘N)"]
         en el auxiliarybar header (sin aria-haspopup). Es el método más rápido.
      2. Fallback DOM/CDP: busca botón via DOM snapshot.
      3. Fallback AppleScript: Command Palette → "Chat: New Chat".

    Si chat_snapshot.txt cambia durante la ejecución (agente activo), aborta.
    """
    vscode_focus()
    time.sleep(0.3)

    if _should_abort_action():
        log("ABORT: chat_snapshot.txt cambió antes de abrir nuevo chat — agente activo", "ACTION")
        return False

    dom_opened = False
    if is_cdp_available():
        try:
            import asyncio as _asyncio

            async def _do_open_chat():
                import asyncio

                playwright, browser, page = await _cdp_connect_workbench_page()
                try:
                    if not page:
                        return False

                    await _cdp_capture_screenshot(page, "open-chat_before")

                    # ── Estrategia 1: Click directo en el botón + via DOM/CDP ──
                    if await _cdp_click_new_chat_plus_button(page):
                        await asyncio.sleep(0.5)
                        await _cdp_capture_screenshot(page, "open-chat_after-direct")
                        return True

                    # ── Estrategia 2: Buscar via DOM snapshot ──
                    snapshot = await _cdp_collect_dom_snapshot(page)
                    direct = _pick_best_action(
                        snapshot.get("items", []),
                        include_any=("new chat", "start new chat", "new conversation", "nuevo chat"),
                        exclude=("mode", "model"),
                        scopes=("chat", "global"),
                    )
                    if direct and await _cdp_click_item(page, direct):
                        await asyncio.sleep(1.2)
                        await _cdp_capture_screenshot(page, "open-chat_after-direct")
                        return True

                    more_actions = _pick_best_action(
                        snapshot.get("items", []),
                        include_any=("more actions", "view and more actions", "view actions"),
                        scopes=("chat", "global"),
                        class_hints=("toolbar-toggle-more",),
                    )
                    if more_actions and await _cdp_click_item(page, more_actions):
                        await asyncio.sleep(0.5)
                        await _cdp_capture_screenshot(page, "open-chat_more-actions")
                        overlay_items = await _cdp_collect_overlay_items(page)
                        menu_target = _pick_best_action(
                            overlay_items,
                            include_any=("new chat", "start new chat", "new conversation", "nuevo chat"),
                            exclude=("mode", "model"),
                            scopes=("overlay",),
                        )
                        if menu_target and await _cdp_click_item(page, menu_target):
                            await asyncio.sleep(1.2)
                            await _cdp_capture_screenshot(page, "open-chat_after-menu")
                            return True

                    return False
                finally:
                    await _cdp_close(playwright, browser)

            dom_opened = _asyncio.run(_do_open_chat())
        except Exception as e:
            log(f"DOM new chat error: {e}", "WARN")

    if not dom_opened:
        run_applescript("""
            tell application "System Events"
                tell process "Code"
                    keystroke "p" using {command down, shift down}
                    delay 0.8
                    keystroke "Chat: New Chat"
                    delay 0.5
                    key code 36
                    delay 2.0
                end tell
            end tell
        """)

    if _should_abort_action():
        log("ABORT: chat_snapshot.txt cambió tras abrir chat — agente activo, cancelando foco", "ACTION")
        return False

    preferred_model = ensure_preferred_model()
    if preferred_model:
        log(f"Modelo preferido asegurado al abrir chat: {preferred_model}", "MODEL")

    capture_workbench_screenshot("open-chat_after-preferred", {"preferred_model": preferred_model})

    focused = _focus_chat_input()
    if not focused:
        capture_workbench_screenshot("open-chat_focus-failed")
        log("Nuevo chat abierto pero no se pudo confirmar foco en chat input", "WARN")
        return False

    capture_workbench_screenshot("open-chat_focused")
    log("Nuevo chat abierto y foco en input del chat confirmado", "ACTION")
    return True


def _focus_chat_input() -> bool:
    """
    Fuerza el foco en el input del chat y verifica que realmente quedó enfocado.

    Por seguridad, el fallback de Command Palette que escribe texto queda
    deshabilitado por defecto porque puede inyectar comandos dentro del chat
    cuando VS Code no enruta bien el foco. Solo se habilita si el operador
    exporta SMART_MONITOR_ENABLE_UNSAFE_CHAT_FOCUS=1.

    Retorna True si el foco quedó confirmado en el chat input,
    False si después de reintentar no se pudo confirmar.
    """
    if is_cdp_available():
        try:
            import asyncio as _asyncio

            async def _dom_focus():
                import asyncio

                playwright, browser, page = await _cdp_connect_workbench_page()
                try:
                    if not page:
                        return False

                    await _cdp_capture_screenshot(page, "focus-input_before")
                    snapshot = await _cdp_collect_dom_snapshot(page)
                    candidates = [item for item in snapshot.get("items", []) if _is_chat_input_candidate(item)]
                    candidates.sort(
                        key=lambda item: (
                            0 if "chat-input-container" in _normalize_ui_text(item.get("class", "")) else
                            1 if "interactive-input-part" in _normalize_ui_text(item.get("class", "")) else
                            2 if "monaco-editor" in _normalize_ui_text(item.get("class", "")) else
                            3 if item.get("tag") == "textarea" else 4,
                            item.get("y", 0),
                        )
                    )

                    for candidate in candidates:
                        if not await _cdp_click_item(page, candidate):
                            continue
                        await asyncio.sleep(0.2)
                        focused = await page.evaluate("""() => {
                            const el = document.activeElement;
                            if (!el) return false;
                            const cls = ((typeof el.className === 'string' ? el.className : '') || '').toLowerCase();
                            const inputContainer = document.querySelector('.chat-input-container, .interactive-input-box, .interactive-input-part, .chat-widget, [class*="chat"], [class*="interactive-input"]');
                            const nearest = el.closest('.chat-input-container, .interactive-input-box, .interactive-input-part, .chat-widget, [class*="chat"], [class*="interactive-input"]');
                            const parent = (((inputContainer || nearest || el).className) || '').toString().toLowerCase();
                            const aria = (el.getAttribute('aria-label') || '').toLowerCase();
                            const placeholder = (el.getAttribute('placeholder') || '').toLowerCase();
                            const editable = el.getAttribute('contenteditable') === 'true';
                            return JSON.stringify({
                                tag: el.tagName.toLowerCase(),
                                cls,
                                parent,
                                aria,
                                placeholder,
                                editable,
                                focusWithin: !!(inputContainer && inputContainer.matches(':focus-within')),
                            });
                        }""")
                        if focused and _looks_like_chat_input_focus(json.loads(focused)):
                            await _cdp_capture_screenshot(page, "focus-input_after-success")
                            return True

                    await _cdp_capture_screenshot(page, "focus-input_after-failed")
                    return False
                finally:
                    await _cdp_close(playwright, browser)

            if _asyncio.run(_dom_focus()):
                return True
        except Exception as e:
            if DEBUG:
                log(f"DOM chat focus error: {e}", "DEBUG")

    allow_unsafe_palette_focus = os.getenv(
        "SMART_MONITOR_ENABLE_UNSAFE_CHAT_FOCUS", ""
    ).strip().lower() in {"1", "true", "yes", "on"}

    if not allow_unsafe_palette_focus:
        log(
            "No se pudo enfocar el input del chat por DOM/CDP; "
            "se omite el fallback inseguro de Command Palette.",
            "WARN",
        )
        return False

    for attempt in range(2):
        vscode_focus()
        run_applescript("""
            tell application "System Events"
                tell process "Code"
                    keystroke "p" using {command down, shift down}
                    delay 0.8
                    keystroke "Focus on Copilot Chat View"
                    delay 0.5
                    key code 36
                    delay 0.8
                end tell
            end tell
        """)
        time.sleep(0.3)
        if is_chat_input_focused():
            if DEBUG and attempt > 0:
                log(f"Foco en chat input confirmado (intento {attempt + 1})", "DEBUG")
            return True
        if attempt == 0:
            log("Foco en chat input no confirmado — reintentando...", "WARN")
            time.sleep(0.5)
    log("No se pudo confirmar foco en chat input tras 2 intentos", "WARN")
    return False


def vscode_send_to_chat(message: str) -> bool:
    """
    Envía `message` al input del chat activo de Copilot.

    Orden obligatorio antes de enviar:
      1. VS Code tiene el foco de aplicación  → vscode_focus()
      2. El chat input tiene el foco           → _focus_chat_input()
      3. Pegar y enviar con Enter
    """
    _begin_action()

    # 1. VS Code al frente
    vscode_focus()

    if _should_abort_action():
        log("ABORT: chat_snapshot.txt cambió durante vscode_focus — agente activo", "ACTION")
        _end_action()
        return False

    # 2. Foco en el chat input (verifica + reintenta internamente)
    _focus_chat_input()

    if _should_abort_action():
        log("ABORT: chat_snapshot.txt cambió durante _focus_chat_input — agente activo", "ACTION")
        _end_action()
        return False

    sent_via_dom = False
    if is_cdp_available():
        try:
            import asyncio as _asyncio

            async def _dom_send():
                import asyncio

                playwright, browser, page = await _cdp_connect_workbench_page()
                try:
                    if not page:
                        return False

                    await _cdp_capture_screenshot(page, "send-message_before", {"message_length": len(message)})
                    snapshot = await _cdp_collect_dom_snapshot(page)
                    input_candidates = [item for item in snapshot.get("items", []) if _is_chat_input_candidate(item)]
                    input_candidates.sort(key=lambda item: (0 if item.get("tag") == "textarea" else 1, item.get("y", 0)))
                    input_target = input_candidates[0] if input_candidates else None
                    if input_target:
                        await _cdp_click_item(page, input_target)
                        await asyncio.sleep(0.2)

                    await page.keyboard.press("Meta+A")
                    await page.keyboard.press("Backspace")
                    await page.keyboard.insert_text(message)
                    await asyncio.sleep(0.2)
                    await page.keyboard.press("Enter")
                    await asyncio.sleep(0.4)
                    await _cdp_capture_screenshot(page, "send-message_after", {"message_length": len(message)})
                    return True
                finally:
                    await _cdp_close(playwright, browser)

            sent_via_dom = _asyncio.run(_dom_send())
        except Exception as e:
            log(f"DOM send error: {e}", "WARN")

    if not sent_via_dom:
        subprocess.run(["pbcopy"], input=message.encode("utf-8"), check=True)
        time.sleep(0.2)
        run_applescript("""
            tell application "System Events"
                tell process "Code"
                    keystroke "v" using {command down}
                    delay 0.5
                    key code 36
                end tell
            end tell
        """)

    log(f"Mensaje enviado al chat ({len(message)} chars)", "ACTION")
    _end_action()
    return True


def vscode_send_continue() -> bool:
    """Envía 'continuar' al chat activo (solo para recuperar de errores)."""
    return vscode_send_to_chat("continuar")


def send_prompt_1() -> bool:
    """Envía el contenido de AGENT_LOOP_PROMPT.md al chat.
    Si el sprint ya está completo (READ al final), avanza al siguiente sprint
    llamando monitor_prompt1.py --next antes de enviar.
    """
    PROMPT_1      = REPO_ROOT / ".prompts" / "prompt_1.md"
    MONITOR_PY    = REPO_ROOT / ".prompts" / "monitor_prompt1.py"
    try:
        text = PROMPT_1.read_text(encoding="utf-8").strip()
    except Exception:
        text = ""

    # Si ya terminó (READ al final) → avanzar al siguiente sprint
    if text.rstrip().endswith("READ") and MONITOR_PY.exists():
        log("prompt_1.md tiene READ — avanzando al siguiente sprint con --next", "ACTION")
        try:
            import subprocess
            result = subprocess.run(
                [sys.executable, str(MONITOR_PY), "--next"],
                capture_output=True, text=True, timeout=15, cwd=str(REPO_ROOT)
            )
            log(f"monitor_prompt1 --next: {result.stdout.strip()[:120]}", "INFO")
        except Exception as e:
            log(f"Error al avanzar sprint: {e}", "ERROR")

    # Enviar siempre el contenido de AGENT_LOOP_PROMPT.md
    try:
        prompt_text = LOOP_PROMPT_FILE.read_text(encoding="utf-8").strip()
    except Exception:
        prompt_text = "Ejecuta las tareas pendientes en .prompts/prompt_1.md"
    log(f"Enviando AGENT_LOOP_PROMPT.md al chat ({len(prompt_text)} chars)", "ACTION")
    return vscode_send_to_chat(prompt_text)


def send_loop_prompt() -> bool:
    """Envía el contenido de AGENT_LOOP_PROMPT.md al chat actual (para nuevo chat)."""
    try:
        prompt_text = LOOP_PROMPT_FILE.read_text(encoding="utf-8").strip()
    except Exception:
        prompt_text = "continuar con las tareas pendientes del sprint actual"
    return vscode_send_to_chat(prompt_text)


# ─── Ejecutores de acción deterministas ──────────────────────────────────────
def execute_action(action: str, state: dict) -> dict:
    now = time.time()

    if action == "wait_and_retry":
        elapsed   = now - state.get("last_rate_limit_ts", 0.0)
        remaining = max(0.0, RATE_LIMIT_WAIT - elapsed)
        state["rate_limit_count"] = state.get("rate_limit_count", 0) + 1

        if remaining > 0:
            # Cooldown activo — el modelo ya fue ciclado, solo loggear y esperar.
            # BUG FIX: NO actualizar last_rate_limit_ts aquí (antes se hacía siempre,
            # lo que reseteaba el cooldown en cada ciclo → nunca expiraba → modelo
            # cambiaba cada 20s en flip-flop y continuar nunca se enviaba).
            log(
                f"Rate limit: cooldown activo — {remaining:.0f}s restantes "
                f"(total detecciones: {state['rate_limit_count']})",
                "RATE_LIMIT",
            )
        else:
            # Cooldown expirado (o primera detección) — ciclar modelo y enviar continuar.
            # BUG FIX: last_rate_limit_ts solo se actualiza aquí (cuando realmente actuamos),
            # para que el siguiente ciclo calcule elapsed desde este momento y respete el
            # cooldown de RATE_LIMIT_WAIT segundos.
            state["last_rate_limit_ts"] = now
            old_model = get_current_model()
            new_model = cycle_model(state, direction=1)
            log(f"RATE LIMIT — modelo {old_model} → {new_model}", "RATE_LIMIT")
            notify("OKLA Monitor", f"Rate limit detectado → {new_model}")

            # Enviar 'continuar' inmediatamente tras el cambio de modelo.
            # BUG FIX: ya no se bloquea con _stall_ok (15 min inactividad).
            # El rate limit DETIENE al agente, por lo que el snapshot seguirá
            # "activo" (VS Code actualiza la UI) y _stall_ok nunca devolvía True,
            # causando que continuar jamás se enviara.
            log(f"Enviando 'continuar' para retomar con {new_model} (rate limit recovery)", "RATE_LIMIT")
            time.sleep(2.0)  # dar tiempo a VS Code para aplicar el cambio de modelo
            vscode_send_continue()
            state["last_continue_ts"] = now
            state["continue_count"]   = state.get("continue_count", 0) + 1
            _mark_post_action(state, "continue", now)

    elif action == "restart_mcp_or_vscode":
        log("Tool validation error — notificando (sin acción automática)", "WARN")
        notify("OKLA Monitor", "Tool validation error — revisar MCP config")

    elif action == "open_new_chat_or_restart":
        if not _stall_ok(state, now):
            remaining = _stall_remaining(state, now)
            log(
                f"Hard error detectado — esperando 15 min de inactividad ({remaining:.0f}s restantes)",
                "INFO",
            )
            return state
        # Primero intentar 'Continuar' en el mismo chat (hasta MAX_ERROR_RETRIES)
        error_retries = state.get("error_continue_count", 0)
        if error_retries < MAX_ERROR_RETRIES:
            log(
                f"Hard error + 15 min inactividad — enviando 'Continuar' al mismo chat "
                f"(intento {error_retries + 1}/{MAX_ERROR_RETRIES})",
                "ACTION",
            )
            vscode_send_continue()
            state["error_continue_count"] = error_retries + 1
            state["last_continue_ts"]     = now
            state["continue_count"]       = state.get("continue_count", 0) + 1
            _mark_post_action(state, "continue", now)
        else:
            # Max retries alcanzado → abrir nuevo chat con prompt completo
            elapsed_new_chat = now - state.get("last_new_chat_ts", 0.0)
            if elapsed_new_chat < NEW_CHAT_COOLDOWN:
                log(
                    f"Hard error — max retries alcanzado pero cooldown activo "
                    f"({NEW_CHAT_COOLDOWN - elapsed_new_chat:.0f}s restantes)",
                    "INFO",
                )
                return state
            old_model = get_current_model()
            new_model = cycle_model(state, direction=1)
            log(f"Hard error + max retries ({MAX_ERROR_RETRIES}) — modelo {old_model} → {new_model} — abriendo nuevo chat", "ACTION")
            notify("OKLA Monitor", f"Hard error → {new_model} — nuevo chat")
            vscode_open_new_chat()
            send_loop_prompt()
            state["last_new_chat_ts"]     = now
            state["new_chat_count"]       = state.get("new_chat_count", 0) + 1
            state["error_continue_count"] = 0
            _mark_post_action(state, "new_chat", now)

    elif action == "observe_or_retry":
        log("Request cancelado — observando siguiente ciclo", "INFO")

    elif action == "check_if_progress_stalled":
        # Post-action gate: si ya enviamos un comando, dejar que la verificación lo maneje
        if state.get("post_action_ts", 0.0) > 0.0:
            if DEBUG:
                log("check_if_progress_stalled: en verificación post-acción — suprimido", "DEBUG")
            return state
        stall_secs = now - state.get("last_activity_ts", now)
        # Usar el evento PREVIO: last_event_type ya fue sobreescrito con "loop_stopped"
        # antes de llamar a execute_action, por lo que el estado anterior se guarda en prev_event_type
        last_event = state.get("prev_event_type", state.get("last_event_type", "unknown"))
        is_error   = last_event in ("rate_limited", "hard_error", "cancelled", "tool_validation_error")
        log(f"Loop detenido — sin actividad útil hace {stall_secs:.0f}s | último evento: {last_event}", "WARN")

        # Helper para abrir nuevo chat con cooldown
        def _open_new_chat_if_ready(reason: str) -> bool:
            elapsed_new_chat = now - state.get("last_new_chat_ts", 0.0)
            if elapsed_new_chat >= NEW_CHAT_COOLDOWN:
                log(f"{reason} — abriendo nuevo chat con AGENT_LOOP_PROMPT", "ACTION")
                vscode_open_new_chat()
                send_loop_prompt()
                state["last_new_chat_ts"]     = now
                state["new_chat_count"]       = state.get("new_chat_count", 0) + 1
                state["error_continue_count"] = 0
                _mark_post_action(state, "new_chat", now)
                return True
            else:
                log(f"{reason} pero cooldown activo ({NEW_CHAT_COOLDOWN - elapsed_new_chat:.0f}s restantes)", "INFO")
                return False

        if stall_secs >= STALL_NEW_CHAT_SECS:
            # Superó el límite máximo de stall (20 min) → forzar nuevo chat
            _open_new_chat_if_ready(f"Stall > {STALL_NEW_CHAT_SECS // 60} min")

        elif stall_secs >= STALL_CONTINUE_SECS:
            elapsed_continue = now - state.get("last_continue_ts", 0.0)
            if elapsed_continue > 60:
                if is_error:
                    # Hay error: intentar con 'continuar', pero respetar MAX_ERROR_RETRIES
                    error_retries = state.get("error_continue_count", 0)
                    if error_retries >= MAX_ERROR_RETRIES:
                        # Demasiados intentos fallidos → nuevo chat
                        log(
                            f"Error persistente tras {error_retries} intentos de 'continuar' "
                            f"({last_event}) — cambiando de chat",
                            "ACTION",
                        )
                        _open_new_chat_if_ready(f"Max retries ({MAX_ERROR_RETRIES}) alcanzado")
                    else:
                        # Todavía hay intentos disponibles → enviar 'continuar'
                        log(
                            f"Stall tras error ({last_event}) — enviando 'continuar' "
                            f"(intento {error_retries + 1}/{MAX_ERROR_RETRIES})",
                            "ACTION",
                        )
                        vscode_send_continue()
                        state["error_continue_count"] = error_retries + 1
                        state["last_continue_ts"]     = now
                        state["continue_count"]       = state.get("continue_count", 0) + 1
                        _mark_post_action(state, "continue", now)
                else:
                    # Sin error → el agente terminó o está inactivo → enviar 'Continuar' primero
                    elapsed_continue = now - state.get("last_continue_ts", 0.0)
                    error_retries = state.get("error_continue_count", 0)
                    if error_retries >= MAX_ERROR_RETRIES:
                        # Demasiados intentos → abrir nuevo chat
                        _open_new_chat_if_ready(f"Sin actividad/sin error + max retries ({MAX_ERROR_RETRIES})")
                    elif elapsed_continue > 60:
                        log(
                            f"Sin actividad y sin error — enviando 'Continuar' al mismo chat "
                            f"(intento {error_retries + 1}/{MAX_ERROR_RETRIES})",
                            "ACTION",
                        )
                        vscode_send_continue()
                        state["error_continue_count"] = error_retries + 1
                        state["last_continue_ts"]     = now
                        state["continue_count"]       = state.get("continue_count", 0) + 1
                        _mark_post_action(state, "continue", now)

    elif action == "do_nothing":
        state["last_activity_ts"]     = now
        state["error_continue_count"] = 0  # éxito → resetear contador de retries

    # keep_monitoring: no hacer nada

    return state


# ─── Ciclo principal ──────────────────────────────────────────────────────────
def run_cycle(state: dict) -> dict:
    now = time.time()
    cdp_used = False
    event_type = "unknown"

    # ═══════════════════════════════════════════════════════════════════
    # FOCUS CHECK: si VS Code no es la app activa, traerlo al frente
    # ═══════════════════════════════════════════════════════════════════
    if not is_vscode_focused():
        log("VS Code perdió el foco — restaurando...", "ACTION")
        vscode_focus()

    # ═══════════════════════════════════════════════════════════════════
    # SIGNAL 0: chat_snapshot.txt — fuente primaria de actividad y errores
    # Si el archivo cambió → actualizar actividad y detectar errores
    # Si lleva ≥ 15 min sin cambios → abrir nuevo chat con AGENT_LOOP_PROMPT
    # ═══════════════════════════════════════════════════════════════════
    if CHAT_SNAPSHOT_FILE.exists():
        try:
            snap_mtime = CHAT_SNAPSHOT_FILE.stat().st_mtime
            last_snap_mtime = state.get("last_snapshot_mtime", 0.0)

            if snap_mtime > last_snap_mtime:
                # Snapshot cambió — verificar si es cambio SIGNIFICATIVO o solo cosmético.
                # El header siempre lleva un timestamp nuevo y el % de progreso fluctúa
                # mientras el modelo genera tokens. Solo un cambio en el CUERPO del chat
                # (nuevos mensajes, herramientas, etc.) debe resetear los timers de stall
                # y de detección de finalización.
                state["last_snapshot_mtime"] = snap_mtime

                # Clasificar cambio y errores desde el contenido del snapshot
                try:
                    snap_content = CHAT_SNAPSHOT_FILE.read_text(encoding="utf-8")
                    new_body_hash = _body_hash(snap_content)
                    prev_body_hash = state.get("last_snapshot_body_hash", "")
                    is_meaningful = (new_body_hash != prev_body_hash and new_body_hash != "")
                    if is_meaningful:
                        # Nuevo contenido real → resetear timers de stall y completion
                        state["last_snapshot_body_hash"] = new_body_hash
                        state["last_activity_ts"] = now
                        state["error_continue_count"] = 0  # reset retries on activity
                        state["model_completion_seen_ts"] = 0.0  # nueva actividad → reset timer
                    # else: solo cambió header/% → no resetear timers (el agente puede haber terminado)
                    tail = snap_content[-1000:] if len(snap_content) > 1000 else snap_content
                    snap_error_found = None
                    for pattern, evt in CHAT_ERROR_PATTERNS:
                        if pattern.search(tail):
                            snap_error_found = evt
                            break

                    if snap_error_found:
                        # Error en snapshot pero el archivo SIGUE CAMBIANDO → agente activo.
                        # No actuar todavía: guardar como pendiente y resetear el timer.
                        # La acción solo se ejecutará si el archivo lleva ≥ 120s sin cambios.
                        is_new_pending = not bool(state.get("pending_snapshot_error"))
                        state["pending_snapshot_error"]       = snap_error_found
                        state["pending_snapshot_error_ts"]    = now  # reset: archivo aún activo
                        state["pending_snapshot_error_mtime"] = snap_mtime
                        if is_new_pending:
                            log(
                                f"SNAPSHOT: error detectado ({snap_error_found}) "
                                f"— archivo activo, esperando 120s sin cambios para actuar",
                                "WARN",
                            )
                        elif DEBUG:
                            log(
                                f"SNAPSHOT: error persistente ({snap_error_found}) "
                                f"— archivo sigue cambiando, timer de 120s reseteado",
                                "DEBUG",
                            )
                    else:
                        # Actividad normal (sin error) → cancelar pending si lo había
                        if state.get("pending_snapshot_error"):
                            log(
                                f"SNAPSHOT: error previo ({state['pending_snapshot_error']}) "
                                f"cancelado — archivo cambió sin error → agente activo",
                                "INFO",
                            )
                            state["pending_snapshot_error"]       = ""
                            state["pending_snapshot_error_ts"]    = 0.0
                            state["pending_snapshot_error_mtime"] = 0.0
                        elif DEBUG:
                            log("SNAPSHOT: actividad normal detectada (mtime actualizado)", "DEBUG")
                except Exception as e:
                    if DEBUG:
                        log(f"SNAPSHOT leer contenido error: {e}", "DEBUG")

            else:
                # Sin cambios en snapshot
                # 1. Verificar error pendiente: si lleva ≥ 15 min sin cambios → confirmar y actuar
                if state.get("pending_snapshot_error") and event_type == "unknown":
                    elapsed_pending = now - state.get("pending_snapshot_error_ts", now)
                    if elapsed_pending >= STALL_CONTINUE_SECS:
                        pend_err = state["pending_snapshot_error"]
                        log(
                            f"SNAPSHOT: error {pend_err} confirmado — "
                            f"{elapsed_pending:.0f}s ({elapsed_pending/60:.1f} min) sin cambios → ejecutando acción",
                            "WARN",
                        )
                        state["pending_snapshot_error"]       = ""
                        state["pending_snapshot_error_ts"]    = 0.0
                        state["pending_snapshot_error_mtime"] = 0.0
                        event_type = pend_err
                    else:
                        remaining_pending = STALL_CONTINUE_SECS - elapsed_pending
                        if DEBUG:
                            log(
                                f"SNAPSHOT: error pendiente ({state['pending_snapshot_error']}) "
                                f"— {remaining_pending:.0f}s restantes (15 min gate)",
                                "DEBUG",
                            )

                # 2. Verificar stall general (solo si no hay error pendiente confirmado)
                stall_secs = now - state.get("last_activity_ts", now)
                if event_type != "unknown":
                    pass  # error pendiente confirmado arriba — no hacer stall check
                elif stall_secs >= STALL_NEW_CHAT_SECS and state.get("post_action_ts", 0.0) == 0.0:
                    # Superó el límite máximo (20 min) → forzar nuevo chat con prompt completo
                    elapsed_new_chat = now - state.get("last_new_chat_ts", 0.0)
                    if elapsed_new_chat >= NEW_CHAT_COOLDOWN:
                        log(
                            f"chat_snapshot.txt inactivo hace {stall_secs:.0f}s "
                            f"(≥ {STALL_NEW_CHAT_SECS}s = 20 min) → abriendo nuevo chat con prompt completo",
                            "ACTION",
                        )
                        notify("OKLA Monitor", f"{stall_secs // 60:.0f} min sin actividad → nuevo chat")
                        vscode_open_new_chat()
                        send_loop_prompt()
                        state["last_new_chat_ts"]     = now
                        state["new_chat_count"]       = state.get("new_chat_count", 0) + 1
                        state["last_activity_ts"]     = now  # reset para evitar loops
                        state["error_continue_count"] = 0
                        _mark_post_action(state, "new_chat", now)
                        save_state(state)
                        return state
                    else:
                        remaining = NEW_CHAT_COOLDOWN - elapsed_new_chat
                        if DEBUG:
                            log(
                                f"SNAPSHOT: inactivo {stall_secs:.0f}s pero cooldown activo "
                                f"({remaining:.0f}s restantes)",
                                "DEBUG",
                            )
                elif stall_secs >= STALL_CONTINUE_SECS and state.get("post_action_ts", 0.0) == 0.0:
                    # 15 min sin actividad → enviar 'Continuar' al mismo chat primero
                    error_retries = state.get("error_continue_count", 0)
                    elapsed_continue = now - state.get("last_continue_ts", 0.0)
                    if error_retries >= MAX_ERROR_RETRIES:
                        # Max retries → forzar nuevo chat
                        elapsed_new_chat = now - state.get("last_new_chat_ts", 0.0)
                        if elapsed_new_chat >= NEW_CHAT_COOLDOWN:
                            log(
                                f"chat_snapshot.txt inactivo + max retries ({MAX_ERROR_RETRIES}) "
                                f"→ abriendo nuevo chat con prompt completo",
                                "ACTION",
                            )
                            notify("OKLA Monitor", f"Max retries → nuevo chat")
                            vscode_open_new_chat()
                            send_loop_prompt()
                            state["last_new_chat_ts"]     = now
                            state["new_chat_count"]       = state.get("new_chat_count", 0) + 1
                            state["last_activity_ts"]     = now
                            state["error_continue_count"] = 0
                            _mark_post_action(state, "new_chat", now)
                            save_state(state)
                            return state
                    elif elapsed_continue > 60:
                        log(
                            f"chat_snapshot.txt inactivo hace {stall_secs:.0f}s "
                            f"(≥ {STALL_CONTINUE_SECS}s = 15 min) → enviando 'Continuar' "
                            f"(intento {error_retries + 1}/{MAX_ERROR_RETRIES})",
                            "ACTION",
                        )
                        notify("OKLA Monitor", f"{stall_secs // 60:.0f} min sin actividad → Continuar")
                        vscode_send_continue()
                        state["error_continue_count"] = error_retries + 1
                        state["last_continue_ts"]     = now
                        state["continue_count"]       = state.get("continue_count", 0) + 1
                        _mark_post_action(state, "continue", now)
                        save_state(state)
                        return state
                elif DEBUG:
                    log(f"SNAPSHOT: sin cambios — última actividad hace {stall_secs:.0f}s", "DEBUG")

            # ── Detección rápida de finalización por footer del modelo ────────────
            # Corre en AMBOS casos (snapshot cambió o no): el nombre del modelo en el
            # footer es la señal definitiva de que el agente terminó su turno.
            #   • Guard: si hay indicador % activo en el tail → modelo generando → no actuar.
            #   • No requiere _stall_ok (15 min): con 45s de footer estable es suficiente.
            if event_type == "unknown":
                try:
                    snap_tail = CHAT_SNAPSHOT_FILE.read_text(encoding="utf-8")[-800:]
                    has_active_gen = bool(re.search(r"\b\d+%\b", snap_tail))
                    if not has_active_gen and MODEL_COMPLETION_PATTERN.search(snap_tail):
                        seen_ts = state.get("model_completion_seen_ts", 0.0)
                        if seen_ts == 0.0:
                            state["model_completion_seen_ts"] = now
                            log(
                                "SNAPSHOT: footer del modelo detectado (sin generación activa) "
                                "— esperando estabilidad antes de abrir nuevo chat",
                                "INFO",
                            )
                        else:
                            stable_secs = now - seen_ts
                            if stable_secs >= MODEL_COMPLETION_STABLE_SECS:
                                elapsed_new_chat = now - state.get("last_new_chat_ts", 0.0)
                                if elapsed_new_chat >= NEW_CHAT_COOLDOWN and state.get("post_action_ts", 0.0) == 0.0:
                                    log(
                                        f"SNAPSHOT: agente terminó — footer estable {stable_secs:.0f}s "
                                        f"→ abriendo nuevo chat con AGENT_LOOP_PROMPT",
                                        "ACTION",
                                    )
                                    notify("OKLA Monitor", "Agente terminó → nuevo chat")
                                    vscode_open_new_chat()
                                    send_loop_prompt()
                                    state["last_new_chat_ts"]         = now
                                    state["new_chat_count"]           = state.get("new_chat_count", 0) + 1
                                    state["last_activity_ts"]         = now
                                    state["model_completion_seen_ts"] = 0.0
                                    state["error_continue_count"]     = 0
                                    _mark_post_action(state, "new_chat", now)
                                    save_state(state)
                                    return state
                                else:
                                    if DEBUG:
                                        remaining_cd = max(0.0, NEW_CHAT_COOLDOWN - elapsed_new_chat)
                                        log(
                                            f"SNAPSHOT: agente terminó (footer {stable_secs:.0f}s) "
                                            f"— cooldown activo ({remaining_cd:.0f}s)",
                                            "DEBUG",
                                        )
                            elif DEBUG:
                                log(
                                    f"SNAPSHOT: footer estable {stable_secs:.0f}s / "
                                    f"{MODEL_COMPLETION_STABLE_SECS}s requeridos",
                                    "DEBUG",
                                )
                    else:
                        if state.get("model_completion_seen_ts", 0.0) != 0.0:
                            if DEBUG:
                                log(
                                    "SNAPSHOT: footer ya no visible o % activo — "
                                    "timer de completion reseteado",
                                    "DEBUG",
                                )
                            state["model_completion_seen_ts"] = 0.0
                except Exception:
                    pass

        except Exception as e:
            if DEBUG:
                log(f"SNAPSHOT check error: {e}", "DEBUG")

    # Si ya se detectó un error desde el snapshot, procesar la acción y salir
    if event_type not in ("unknown", "success"):
        action = ACTIONS.get(event_type, "keep_monitoring")
        log(f"SNAPSHOT evento: {event_type} → Acción: {action}")
        state["prev_event_type"] = state.get("last_event_type", "unknown")
        state["last_event_type"] = event_type
        state["last_event_ts"]   = now
        state = execute_action(action, state)
        return state

    # ═══════════════════════════════════════════════════════════════════
    # SIGNAL 1: CDP — leer el chat directamente del DOM (complementario)
    # ═══════════════════════════════════════════════════════════════════
    if is_cdp_available():
        chat_text = read_chat_via_cdp()
        if chat_text:
            cdp_used = True
            prev_hash = state.get("chat_hash", "")
            event_type, has_changed = classify_chat_text(chat_text, prev_hash)
            state["chat_hash"] = _text_hash(chat_text)
            state["chat_len"]  = len(chat_text)

            # ── Detección de contexto lleno ──────────────────────────────────
            # Si el texto visible supera el límite, detenemos y abrimos nuevo
            # chat INMEDIATAMENTE, independientemente de si hay actividad en
            # chat_snapshot.txt. El gate de 15 min NO aplica aquí — el tamaño
            # del contexto es una señal dura que no puede ignorarse.
            # Solo se respeta el cooldown (120s) para evitar bucles.
            if len(chat_text) >= CONTEXT_SIZE_LIMIT:
                elapsed_new_chat = now - state.get("last_new_chat_ts", 0.0)
                if elapsed_new_chat >= NEW_CHAT_COOLDOWN:
                    log(
                        f"CONTEXTO LLENO: {len(chat_text):,} chars ≥ {CONTEXT_SIZE_LIMIT:,} "
                        f"— deteniendo y abriendo nuevo chat (sin esperar inactividad)",
                        "WARN",
                    )
                    open_new_chat_with_stop()
                    state["last_new_chat_ts"]     = now
                    state["new_chat_count"]       = state.get("new_chat_count", 0) + 1
                    state["last_activity_ts"]     = now
                    state["error_continue_count"] = 0
                    state["chat_len"]             = 0   # reset tras el cambio
                    save_state(state)
                    return state
                else:
                    remaining_cd = max(0.0, NEW_CHAT_COOLDOWN - elapsed_new_chat)
                    log(
                        f"Contexto lleno ({len(chat_text):,} chars) — cooldown activo "
                        f"({remaining_cd:.0f}s restantes)",
                        "INFO",
                    )

            if has_changed:
                state["last_activity_ts"] = now
                # Guardar snapshot para agentes externos
                try:
                    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                    CHAT_SNAPSHOT_FILE.write_text(
                        f"# Chat Snapshot — {ts}\n\n{chat_text}\n",
                        encoding="utf-8",
                    )
                except Exception:
                    pass
                if DEBUG:
                    log(f"CDP: chat cambió ({len(chat_text)} chars) → {event_type}", "DEBUG")
            else:
                stall_secs = now - state.get("last_activity_ts", now)
                if stall_secs >= STALL_CONTINUE_SECS:
                    event_type = "loop_stopped"
                    log(f"CDP: chat sin cambios hace {stall_secs:.0f}s → loop_stopped")
                elif DEBUG:
                    log(f"CDP: sin cambios — última actividad hace {stall_secs:.0f}s", "DEBUG")
                    return state
        else:
            if DEBUG:
                log("CDP: no se pudo leer el chat — fallback a logs", "DEBUG")

    # ═══════════════════════════════════════════════════════════════════
    # SIGNAL 2: Log file — fallback si CDP no está disponible o falló
    # ═══════════════════════════════════════════════════════════════════
    if not cdp_used:
        # 1. Descubrir log activo (cambia si VS Code se reinicia)
        log_path = find_copilot_log()
        if log_path is None:
            log("Log de Copilot no encontrado — VS Code corriendo?", "WARN")
            return state

        current_log_str = str(log_path)
        if current_log_str != state.get("log_path", ""):
            log(f"Nuevo log detectado: {log_path}")
            state["log_path"]         = current_log_str
            state["log_offset"]       = 0
            state["last_activity_ts"] = now  # reset stall — nueva sesión de log

        # 2. Leer solo líneas nuevas
        prev_offset = state.get("log_offset", 0)
        lines, new_offset = read_new_lines(log_path, prev_offset)
        if new_offset < prev_offset:
            log(f"Rotación de log detectada (offset {prev_offset} → {new_offset}) — reseteando stall")
            state["last_activity_ts"] = now
        state["log_offset"] = new_offset

        if DEBUG and lines:
            log(f"Leídas {len(lines)} líneas nuevas (offset {state['log_offset']:,})", "DEBUG")

        # 3. Clasificar
        event_type, meaningful_count = classify_lines(lines)

        if lines and event_type != "loop_stopped":
            state["last_activity_ts"] = now

        # Sin líneas nuevas → verificar mtime del log como segunda señal
        if not lines:
            try:
                log_mtime = log_path.stat().st_mtime
                last_known_mtime = state.get("last_log_mtime", 0.0)
                if log_mtime > last_known_mtime:
                    state["last_log_mtime"] = log_mtime
                    state["last_activity_ts"] = now
                    if DEBUG:
                        log("Log mtime actualizado — agente activo", "DEBUG")
                    return state
                state["last_log_mtime"] = log_mtime
            except Exception:
                pass

            stall_secs = now - state.get("last_activity_ts", now)
            if stall_secs >= STALL_CONTINUE_SECS:
                event_type = "loop_stopped"
                log(f"Sin líneas nuevas y estancado hace {stall_secs:.0f}s → loop_stopped")
            else:
                if DEBUG:
                    log(f"Sin líneas nuevas — última actividad hace {stall_secs:.0f}s", "DEBUG")
                return state

    state["cdp_active"] = cdp_used

    # ═══════════════════════════════════════════════════════════════════
    # POST-ACTION VERIFICATION: Si enviamos un comando recientemente,
    # verificar si el agente se normalizó antes de lanzar nuevas acciones.
    # Solo se saltan eventos no-error (stalls). Errores reales (rate_limit,
    # hard_error) siguen su flujo normal aunque haya verificación activa.
    # ═══════════════════════════════════════════════════════════════════
    if state.get("post_action_ts", 0.0) > 0.0 and event_type in ("unknown", "loop_stopped"):
        _, state = _handle_post_action_verification(state, now)
        save_state(state)
        return state

    action = ACTIONS.get(event_type, "keep_monitoring")

    # No loggear eventos ruidosos en cada ciclo (solo si DEBUG)
    if event_type not in ("unknown", "success", "tool_validation_error") or DEBUG:
        log(f"Evento: {event_type} → Acción: {action}")

    # Bug fix: suprimir tool_validation_error ANTES de actualizar el estado
    # (evita que last_event_type quede persistido como error cuando es spam de MCP)
    if event_type == "tool_validation_error":
        stall_secs = now - state.get("last_activity_ts", now)
        if stall_secs < 120:
            if DEBUG:
                log("tool_validation_error ignorado (actividad reciente OK)", "DEBUG")
            return state

    state["prev_event_type"] = state.get("last_event_type", "unknown")  # guardar antes de sobreescribir
    state["last_event_type"] = event_type
    state["last_event_ts"]   = now

    state = execute_action(action, state)
    return state


