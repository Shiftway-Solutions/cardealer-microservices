def open_new_chat_option(option_text: str = "New Chat") -> bool:
    """
    Opens a specific option from the +v new chat dropdown.

    Args:
        option_text: One of:
          - "New Chat"              (default, standard chat panel)
          - "New Chat Editor"       (opens chat in editor tab)
          - "New Chat Window"       (separate VS Code window)
          - "New Codex Agent"       (autonomous coding agent)
          - "New Copilot CLI Session"  (terminal-integrated session)

    Returns True if the option was clicked successfully.
    """
    if not is_cdp_available():
        # Fallback: Command Palette
        vscode_focus()
        safe_option = option_text.replace("\\", "\\\\").replace('"', '\\"')
        run_applescript(f"""
            tell application "System Events"
                tell process "Code"
                    keystroke "p" using {{command down, shift down}}
                    delay 0.8
                    keystroke "{safe_option}"
                    delay 0.5
                    key code 36
                    delay 1.5
                end tell
            end tell
        """)
        return True

    try:
        vscode_focus()
        time.sleep(0.5)
        import asyncio as _asyncio

        async def _do_open():
            import asyncio
            playwright, browser, page = await _cdp_connect_workbench_page()
            try:
                if not page:
                    return False
                await _cdp_capture_screenshot(page, f"open-option_before")

                header_btns = await page.evaluate(r"""() => {
                    const items = [];
                    for (const el of document.querySelectorAll(
                        '.actions-container a[role="button"], .panel .action-item a[role="button"]'
                    )) {
                        const rect = el.getBoundingClientRect();
                        if (rect.width === 0 || rect.y < 35 || rect.y > 130) continue;
                        const label = (el.getAttribute('aria-label') || el.innerText || '').replace(/\s+/g, ' ').trim();
                        items.push({ label, x: rect.x + rect.width / 2, y: rect.y + rect.height / 2 });
                    }
                    return items;
                }""")

                option_norm = _normalize_ui_text(option_text)

                # If "New Chat" and directly available, click it
                if option_norm in ("new chat", "new chat (⌘n)"):
                    direct = next(
                        (b for b in header_btns if option_norm in _normalize_ui_text(b["label"])),
                        None,
                    )
                    if direct:
                        await page.mouse.click(direct["x"], direct["y"])
                        await asyncio.sleep(1.2)
                        await _cdp_capture_screenshot(page, f"open-option_direct")
                        log(f"Nuevo chat abierto directamente: {direct['label']}", "ACTION")
                        return True

                # Open the dropdown
                dropdown_btn = None
                for btn in header_btns:
                    if "new" in btn["label"].lower() or "chat" in btn["label"].lower():
                        dropdown_btn = btn
                        break
                if not dropdown_btn and header_btns:
                    dropdown_btn = header_btns[0]
                if not dropdown_btn:
                    return False

                await page.mouse.click(dropdown_btn["x"], dropdown_btn["y"])
                await asyncio.sleep(0.6)

                menu_items = await page.evaluate(r"""() => {
                    const results = [];
                    for (const sel of ['.context-view .monaco-list-row', '.monaco-menu .action-item']) {
                        for (const el of document.querySelectorAll(sel)) {
                            const rect = el.getBoundingClientRect();
                            if (rect.width === 0) continue;
                            const text = (el.innerText || '').replace(/\s+/g, ' ').trim();
                            if (!text) continue;
                            results.push({ text, x: rect.x + rect.width/2, y: rect.y + rect.height/2 });
                        }
                    }
                    return results.slice(0, 20);
                }""")

                target = next(
                    (item for item in menu_items if option_norm in _normalize_ui_text(item["text"])),
                    None,
                )
                if not target:
                    await page.keyboard.press("Escape")
                    log(f"Opción '{option_text}' no encontrada en dropdown", "WARN")
                    return False

                await page.mouse.click(target["x"], target["y"])
                await asyncio.sleep(1.2)
                await _cdp_capture_screenshot(page, f"open-option_after")
                log(f"Opción de chat abierta: {target['text']}", "ACTION")
                return True
            finally:
                await _cdp_close(playwright, browser)

        return _asyncio.run(_do_open())
    except Exception as e:
        log(f"open_new_chat_option error: {e}", "WARN")
        return False


