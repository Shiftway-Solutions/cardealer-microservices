async def _cdp_ensure_sessions_panel_visible(page) -> bool:
    """
    Ensures the chat sessions list panel is visible (monaco-list-rows have y > 0).

    When a conversation is open and the sessions sidebar is collapsed, all
    .monaco-list-row elements report x=0, y=0.  To make them visible we
    open a new (empty) chat via the + button — this switches to the sessions
    view where all past chats are shown and clickable.

    Returns True if the panel is now visible, False if it couldn't be opened.
    """
    import asyncio

    # Check if sessions rows are already visible
    visible = await page.evaluate(r"""() => {
        const rows = document.querySelectorAll('#workbench\\.panel\\.chat .monaco-list-row');
        return [...rows].some(el => el.getBoundingClientRect().width > 0);
    }""")
    if visible:
        return True

    log("DOM/CDP: sessions panel no visible, abriendo nuevo chat para mostrar lista de sesiones", "ACTION")
    opened = await _cdp_click_new_chat_plus_button(page)
    if not opened:
        return False

    await asyncio.sleep(0.6)
    visible_after = await page.evaluate(r"""() => {
        const rows = document.querySelectorAll('#workbench\\.panel\\.chat .monaco-list-row');
        return [...rows].some(el => el.getBoundingClientRect().width > 0);
    }""")
    return visible_after


def navigate_to_chat_by_title(title: str) -> bool:
    """
    Navigates to a specific chat conversation by its title using pure DOM/CDP.

    Flow:
      1. Connect to VS Code via CDP.
      2. If the sessions panel is not visible (rows at y=0), open a new chat via
         the + button — this reveals the sessions list.
      3. Find the monaco-list-row whose ariaLabel contains the target title.
      4. CDP mouse.click on the row's center coordinates.
      5. Verify navigation by reading the new chat title.

    Returns True if navigation succeeded.
    """
    if not is_cdp_available():
        return False

    try:
        vscode_focus()
        time.sleep(0.3)
        import asyncio as _asyncio

        async def _do_navigate():
            import asyncio
            playwright, browser, page = await _cdp_connect_workbench_page()
            try:
                if not page:
                    return False

                # Step 1: ensure sessions panel is visible via DOM/CDP
                panel_visible = await _cdp_ensure_sessions_panel_visible(page)
                if not panel_visible:
                    log("No se pudo mostrar el panel de sesiones via DOM/CDP", "WARN")
                    return False

                # Step 2: read all visible rows
                history = await _cdp_get_chat_history(page)
                if not history:
                    log("Historial de chats vacío después de abrir sesiones panel", "WARN")
                    return False

                # Step 3: find target row by title only (NOT fullText to avoid false matches)
                # Skip rows with y ≤ 0 (scrolled off top) — they'll be scrolled into view anyway
                title_norm = _normalize_ui_text(title)
                target = None
                for item in history:
                    item_title_norm = _normalize_ui_text(item.get("title", ""))
                    item_aria_norm = _normalize_ui_text(item.get("ariaLabel", ""))
                    if title_norm in item_title_norm or title_norm in item_aria_norm:
                        target = item
                        break

                if not target:
                    visible_titles = [
                        item.get("title", "")[:40]
                        for item in history
                        if item.get("y", 0) > 0
                    ][:10]
                    log(f"Chat '{title}' no encontrado. Visibles: {visible_titles}", "WARN")
                    return False

                log(f"DOM/CDP: click JS directo en chat '{target.get('title','')}' (dataIndex={target.get('dataIndex','')})", "ACTION")
                await _cdp_capture_screenshot(page, "navigate-chat_before")

                # Use JS .click() directly — avoids coordinate issues with Monaco virtual scrolling
                clicked = await page.evaluate(r"""(dataIndex) => {
                    const rows = document.querySelectorAll('#workbench\\.panel\\.chat .monaco-list-row');
                    let el = null;
                    // Match by data-index first
                    if (dataIndex !== '') {
                        el = [...rows].find(r => r.getAttribute('data-index') === String(dataIndex));
                    }
                    if (!el) return false;
                    el.scrollIntoView({ block: 'nearest', behavior: 'instant' });
                    el.click();
                    return true;
                }""", target.get("dataIndex", ""))

                if not clicked:
                    log(f"JS click falló para chat '{target.get('title','')}', intentando mouse.click con coords originales", "WARN")
                    if target.get("y", 0) > 0:
                        await page.mouse.click(target["x"], target["y"])
                    else:
                        return False

                await asyncio.sleep(1.0)
                await _cdp_capture_screenshot(page, "navigate-chat_after")
                new_title = await _cdp_get_current_chat_title(page)
                log(f"Navegado a chat: '{new_title}' (buscado: '{title}')", "ACTION")
                return True
            finally:
                await _cdp_close(playwright, browser)

        return _asyncio.run(_do_navigate())
    except Exception as e:
        log(f"navigate_to_chat_by_title error: {e}", "WARN")
        return False


# ─── Enhanced Stop Response Detection ────────────────────────────────────────

def is_response_generating() -> bool:
    """
    Checks if a model response is currently being generated.

    Detection strategy (ordered by speed):
      1. chat_snapshot.txt changed in the last 5 seconds → generating
      2. CDP: Stop button is visible in DOM (only shown while generating)
      3. CDP: Spinner/progress indicator visible

    Returns True if generating, False if idle/unknown.
    """
    # Fast path: recent snapshot change
    try:
        if CHAT_SNAPSHOT_FILE.exists():
            mtime = CHAT_SNAPSHOT_FILE.stat().st_mtime
            if time.time() - mtime < 5.0:
                return True
    except Exception:
        pass

    if not is_cdp_available():
        return False

    try:
        import asyncio as _asyncio

        async def _do_check():
            playwright, browser, page = await _cdp_connect_workbench_page()
            try:
                if not page:
                    return False
                return await page.evaluate(r"""() => {
                    const stopSels = [
                        'button[aria-label="Stop Response"]',
                        'button[aria-label*="Stop" i]',
                        '.interactive-stop-button',
                        '.chat-stop-button',
                        'button.codicon-debug-stop',
                        '[class*="codicon-stop-circle"]',
                    ];
                    for (const sel of stopSels) {
                        const el = document.querySelector(sel);
                        if (el && el.getBoundingClientRect().width > 0) return true;
                    }
                    const spinner = document.querySelector(
                        '.chat-progress-task, .interactive-response-progress-tree, .codicon-loading'
                    );
                    return !!(spinner && spinner.getBoundingClientRect().width > 0);
                }""")
            finally:
                await _cdp_close(playwright, browser)

        return _asyncio.run(_do_check())
    except Exception as e:
        if DEBUG:
            log(f"is_response_generating check error: {e}", "DEBUG")
        return False


