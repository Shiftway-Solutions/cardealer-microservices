def ensure_preferred_model() -> str:
    catalog = discover_available_models() or load_model_catalog()
    models = catalog.get("models", []) if isinstance(catalog, dict) else []
    preferred = next((item for item in models if item.get("preferred")), None)
    if not preferred:
        return ""

    current_label = get_current_model_label()
    current_norm = _normalize_ui_text(current_label)
    if current_norm and preferred["id"] in _slugify_model_label(current_label):
        return preferred["id"]
    if current_norm and _normalize_ui_text(preferred["label"]) in current_norm:
        return preferred["id"]

    if set_model(preferred["id"]):
        return preferred["id"]
    return ""


def set_model(model_id: str) -> bool:
    """Cambia el modelo via DOM/CDP y persiste metadata descubierta del picker."""
    if not is_cdp_available():
        _persist_setting_model(model_id)
        log(f"Modelo persistido en settings.json: {model_id} (sin CDP activo)", "MODEL")
        return True

    try:
        vscode_focus()
        time.sleep(0.5)
        import asyncio as _asyncio

        async def _cdp_set_model():
            import asyncio

            playwright, browser, page = await _cdp_connect_workbench_page()
            try:
                if not page:
                    return False, None, []

                current_label = await _cdp_read_selected_model_label(page)
                screenshots = []
                screenshots.append(
                    await _cdp_capture_screenshot(
                        page,
                        f"set-model_before_{model_id}",
                        {"current_model_label": current_label, "requested_model": model_id},
                    )
                )
                if current_label and _resolve_model_reference(model_id, [{
                    "id": _slugify_model_label(current_label),
                    "label": current_label,
                    "raw_text": current_label,
                    "preferred": _matches_preferred_model(current_label),
                }]):
                    return True, {
                        "id": _slugify_model_label(current_label),
                        "label": current_label,
                        "raw_text": current_label,
                        "preferred": _matches_preferred_model(current_label),
                    }, []

                if not await _cdp_open_model_picker(page):
                    return False, None, []

                await asyncio.sleep(0.6)
                screenshots.append(
                    await _cdp_capture_screenshot(
                        page,
                        f"set-model_picker_{model_id}",
                        {"current_model_label": current_label, "requested_model": model_id},
                    )
                )
                catalog_entries = []
                root_items = await _cdp_collect_overlay_items(page)
                for item in root_items:
                    entry = _extract_model_entry(item, "root", current_label)
                    if entry:
                        catalog_entries.append(entry)

                target_entry = _resolve_model_reference(model_id, catalog_entries)
                if not target_entry:
                    other_models = _pick_best_action(
                        root_items,
                        include_any=("other models", "more models", "browse models"),
                        scopes=("overlay",),
                    )
                    if other_models and await _cdp_click_item(page, other_models):
                        await asyncio.sleep(0.6)
                        screenshots.append(
                            await _cdp_capture_screenshot(
                                page,
                                f"set-model_other-models_{model_id}",
                                {"current_model_label": current_label, "requested_model": model_id},
                            )
                        )
                        nested_items = await _cdp_collect_overlay_items(page)
                        for item in nested_items:
                            entry = _extract_model_entry(item, "other-models", current_label)
                            if entry:
                                catalog_entries.append(entry)
                        target_entry = _resolve_model_reference(model_id, catalog_entries)

                catalog = _build_model_catalog(catalog_entries, current_label)
                _write_json_file(MODEL_CATALOG_FILE, catalog)

                if not target_entry:
                    await page.keyboard.press("Escape")
                    await asyncio.sleep(0.2)
                    await page.keyboard.press("Escape")
                    return False, None, catalog_entries

                target_element = _pick_best_action(
                    await _cdp_collect_overlay_items(page),
                    include_any=(_normalize_ui_text(target_entry["label"]),),
                    scopes=("overlay",),
                )
                if not target_element:
                    target_element = _pick_best_action(
                        await _cdp_collect_overlay_items(page),
                        include_any=tuple(filter(None, _normalize_ui_text(target_entry["label"]).split()[:2])),
                        scopes=("overlay",),
                    )
                if not target_element:
                    await page.keyboard.press("Escape")
                    await asyncio.sleep(0.2)
                    await page.keyboard.press("Escape")
                    return False, target_entry, catalog_entries

                await _cdp_click_item(page, target_element)
                await asyncio.sleep(0.6)
                new_label = await _cdp_read_selected_model_label(page)
                screenshots.append(
                    await _cdp_capture_screenshot(
                        page,
                        f"set-model_after_{model_id}",
                        {"current_model_label": new_label, "requested_model": model_id},
                    )
                )
                new_slug = _slugify_model_label(new_label)
                target_slug = target_entry["id"]
                target_norm = _normalize_ui_text(target_entry["label"])
                new_norm = _normalize_ui_text(new_label)
                selected_ok = (
                    target_slug == new_slug
                    or target_slug.startswith(new_slug) or new_slug.startswith(target_slug)
                    or target_norm in new_norm or new_norm in target_norm
                )
                return selected_ok, target_entry, catalog_entries
            finally:
                await _cdp_close(playwright, browser)

        ok, target_entry, catalog_entries = _asyncio.run(_cdp_set_model())
        _persist_setting_model(model_id, target_entry)
        if ok and target_entry:
            log(f"Modelo cambiado via UI: {target_entry['label']}", "MODEL")
            return True
        if catalog_entries:
            items = ", ".join(sorted({entry['label'] for entry in catalog_entries}))
            log(f"Modelo '{model_id}' no encontrado en el picker. Disponibles: {items}", "WARN")
        else:
            log(f"Modelo '{model_id}' no encontrado en el picker.", "WARN")
    except Exception as e:
        log(f"CDP model switch error: {e}", "WARN")

    log(f"Modelo persistido en settings.json: {model_id} (requiere nuevo chat para tomar efecto)", "MODEL")
    return True


def cycle_model(state: dict, direction: int = 1) -> str:
    """Cicla modelos descubiertos dinámicamente, priorizando 1x y luego 3x."""
    pool = get_model_pool()
    if not pool:
        pool = list(MODEL_POOL)

    current_label = get_current_model_label()
    current = _slugify_model_label(current_label) or get_current_model()
    current_idx = -1
    for i, model in enumerate(pool):
        if model == current:
            current_idx = i
            break

    if current_idx < 0:
        new_idx = 0
    else:
        new_idx = (current_idx + direction) % len(pool)

    new_model = pool[new_idx]
    set_model(new_model)
    state["current_model"] = new_model
    state["model_index"] = new_idx
    return new_model


