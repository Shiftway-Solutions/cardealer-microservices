def get_current_model() -> str:
    """Lee el modelo activo persistido en settings.json de VS Code."""
    try:
        import re as _re
        raw = VSCODE_SETTINGS.read_text(encoding="utf-8")
        m = _re.search(r'"github\.copilot\.chat\.languageModel"\s*:\s*"([^"]+)"', raw)
        return m.group(1) if m else ""
    except Exception:
        return ""


def _normalize_ui_text(value: str) -> str:
    return re.sub(r"\s+", " ", (value or "").replace("·", " ").strip()).lower()


def _slugify_model_label(label: str) -> str:
    slug = _normalize_ui_text(label).replace("x high", "xhigh")
    slug = re.sub(r"[^a-z0-9.]+", "-", slug)
    return slug.strip("-")


def _element_blob(item: dict) -> str:
    return _normalize_ui_text(
        " ".join(
            str(item.get(key, ""))
            for key in ("text", "aria", "title", "placeholder", "class", "id", "role")
        )
    )


def _serialize_ui_item(item: dict) -> dict:
    return {
        "tag": item.get("tag", ""),
        "role": item.get("role", ""),
        "aria": item.get("aria", ""),
        "title": item.get("title", ""),
        "placeholder": item.get("placeholder", ""),
        "text": item.get("text", ""),
        "class": item.get("class", ""),
        "id": item.get("id", ""),
        "scope": item.get("scope", ""),
        "editable": item.get("editable", ""),
        "x": round(float(item.get("x", 0) or 0), 2),
        "y": round(float(item.get("y", 0) or 0), 2),
        "width": round(float(item.get("width", 0) or 0), 2),
        "height": round(float(item.get("height", 0) or 0), 2),
    }


def _serialized_ui_item_key(item: dict) -> tuple:
    return (
        item.get("tag", ""),
        item.get("role", ""),
        _normalize_ui_text(item.get("aria", "")),
        _normalize_ui_text(item.get("text", "")),
        _normalize_ui_text(item.get("class", "")),
    )


def _dedupe_serialized_items(items: list[dict]) -> list[dict]:
    seen = set()
    ordered = []
    for item in sorted(items, key=lambda value: (value.get("y", 0), value.get("x", 0), value.get("text", ""), value.get("aria", ""))):
        key = _serialized_ui_item_key(item) + (item.get("x", 0), item.get("y", 0))
        if key in seen:
            continue
        seen.add(key)
        ordered.append(item)
    return ordered


def _subtract_serialized_items(items: list[dict], references: list[dict]) -> list[dict]:
    reference_keys = {_serialized_ui_item_key(item) for item in references}
    return [item for item in items if _serialized_ui_item_key(item) not in reference_keys]


def _collect_model_picker_controls(snapshot: dict) -> list[dict]:
    controls = []
    for item in snapshot.get("items", []):
        if item.get("scope") != "chat":
            continue
        item_class = _normalize_ui_text(item.get("class", ""))
        blob = _element_blob(item)
        near_bottom = float(item.get("y", 0) or 0) >= 720
        if any(
            hint in item_class
            for hint in (
                "chat-input-picker-item",
                "chat-input-toolbar",
                "chat-input-toolbars",
                "chat-input-container",
                "chat-editor-container",
                "interactive-input-editor",
                "interactive-input-part",
                "monaco-editor",
                "ime-text-area",
            )
        ):
            controls.append(_serialize_ui_item(item))
            continue
        if near_bottom and any(
            token in blob
            for token in (
                "add context",
                "agent",
                "pick model",
                "gpt",
                "claude",
                "configure tools",
                "local",
                "approvals",
                "cancel",
            )
        ):
            controls.append(_serialize_ui_item(item))
    return _dedupe_serialized_items(controls)


def _serialize_model_entries(entries: list[dict]) -> list[dict]:
    seen = set()
    serialized = []
    for entry in entries:
        key = (entry.get("source_menu", ""), _normalize_ui_text(entry.get("raw_text") or entry.get("label", "")))
        if key in seen:
            continue
        seen.add(key)
        serialized.append({
            "id": entry.get("id", ""),
            "label": entry.get("label", ""),
            "raw_text": entry.get("raw_text", ""),
            "multiplier": entry.get("multiplier"),
            "multiplier_label": entry.get("multiplier_label", ""),
            "source_menu": entry.get("source_menu", ""),
            "selected": bool(entry.get("selected")),
            "preferred": bool(entry.get("preferred")),
        })
    return serialized


def _build_picker_selection_paths(root_entries: list[dict], nested_entries: list[dict]) -> list[dict]:
    seen = set()
    paths = []
    for entry in list(root_entries) + list(nested_entries):
        key = (entry.get("source_menu", ""), entry.get("id", ""), _normalize_ui_text(entry.get("label", "")))
        if key in seen:
            continue
        seen.add(key)
        paths.append({
            "id": entry.get("id", ""),
            "label": entry.get("label", ""),
            "menu": entry.get("source_menu", ""),
            "preferred": bool(entry.get("preferred")),
            "selected": bool(entry.get("selected")),
        })
    return paths


def _matches_preferred_model(text: str) -> bool:
    norm = _normalize_ui_text(text).replace("x high", "xhigh")
    has_gpt_54 = "gpt-5.4" in norm or "gpt 5.4" in norm
    return has_gpt_54 and "xhigh" in norm


def _write_json_file(path: Path, payload: dict) -> None:
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(json.dumps(payload, indent=2, ensure_ascii=False), encoding="utf-8")
    except Exception as e:
        log(f"No se pudo escribir {path.name}: {e}", "WARN")


def _slugify_artifact_name(value: str) -> str:
    slug = re.sub(r"[^a-zA-Z0-9._-]+", "-", (value or "capture").strip().lower())
    return slug.strip("-.") or "capture"


def _load_json_file(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def load_model_catalog() -> dict:
    return _load_json_file(MODEL_CATALOG_FILE)


def _resolve_setting_model_id(model_ref: str, model_entry: dict | None = None) -> str:
    if model_entry:
        known = MODEL_LABEL_TO_ID.get(_normalize_ui_text(model_entry.get("label", "")))
        if known:
            return known

    norm_ref = _normalize_ui_text(model_ref)
    if norm_ref in MODEL_LABEL_TO_ID:
        return MODEL_LABEL_TO_ID[norm_ref]

    if re.fullmatch(r"[a-z0-9.-]+", model_ref or ""):
        return model_ref

    return ""


def _persist_setting_model(model_ref: str, model_entry: dict | None = None) -> None:
    setting_id = _resolve_setting_model_id(model_ref, model_entry)
    if not setting_id:
        return

    try:
        import re as _re

        raw = VSCODE_SETTINGS.read_text(encoding="utf-8")
        pattern = r'"github\.copilot\.chat\.languageModel"\s*:\s*"[^"]*"'
        replacement = f'"github.copilot.chat.languageModel": "{setting_id}"'
        if _re.search(pattern, raw):
            new_raw = _re.sub(pattern, replacement, raw)
        else:
            new_raw = raw.replace("{", "{\n  " + replacement + ",", 1)
        VSCODE_SETTINGS.write_text(new_raw, encoding="utf-8")
    except Exception as e:
        log(f"Error escribiendo settings.json: {e}", "WARN")


async def _cdp_connect_workbench_page():
    from playwright.async_api import async_playwright

    playwright = await async_playwright().start()
    browser = None
    try:
        browser = await playwright.chromium.connect_over_cdp(f"http://{CDP_HOST}:{CDP_PORT}")
        page = None
        for ctx in browser.contexts:
            for pg in ctx.pages:
                if any(token in pg.url for token in ("workbench", "copilot", "chat")):
                    page = pg
                    break
            if page:
                break

        if not page and browser.contexts and browser.contexts[0].pages:
            page = browser.contexts[0].pages[0]

        if page is not None:
            try:
                await page.bring_to_front()
            except Exception:
                pass

        return playwright, browser, page
    except Exception:
        if browser is not None:
            await browser.close()
        await playwright.stop()
        raise


async def _cdp_close(playwright, browser) -> None:
    try:
        if browser is not None:
            await browser.close()
    finally:
        if playwright is not None:
            await playwright.stop()


async def _cdp_capture_screenshot(page, label: str, extra: dict | None = None) -> str:
    SCREENSHOT_DIR.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y%m%d_%H%M%S_%f")
    stem = f"{ts}_{_slugify_artifact_name(label)}"
    png_path = SCREENSHOT_DIR / f"{stem}.png"
    json_path = SCREENSHOT_DIR / f"{stem}.json"

    try:
        await page.screenshot(path=str(png_path), full_page=True)
        metadata = {
            "captured_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "label": label,
            "png_path": str(png_path),
            "url": page.url,
            "title": await page.title(),
        }
        if extra:
            metadata.update(extra)
        _write_json_file(json_path, metadata)
        log(f"Screenshot guardado: {png_path}", "SCREEN")
        return str(png_path)
    except Exception as e:
        log(f"No se pudo capturar screenshot '{label}': {e}", "WARN")
        return ""


def capture_workbench_screenshot(label: str = "manual", extra: dict | None = None) -> str:
    if not is_cdp_available():
        return ""

    try:
        import asyncio as _asyncio

        async def _capture_once():
            playwright, browser, page = await _cdp_connect_workbench_page()
            try:
                if not page:
                    return ""
                return await _cdp_capture_screenshot(page, label, extra)
            finally:
                await _cdp_close(playwright, browser)

        return _asyncio.run(_capture_once())
    except Exception as e:
        log(f"Screenshot manual falló: {e}", "WARN")
        return ""


async def _cdp_collect_dom_snapshot(page) -> dict:
    return await page.evaluate(r"""() => {
        const clean = (value, limit = 180) => (value || '').replace(/\s+/g, ' ').trim().slice(0, limit);
        const visible = (el) => {
            if (!el) return false;
            const rect = el.getBoundingClientRect();
            const style = window.getComputedStyle(el);
            return rect.width > 0 && rect.height > 0 && style.visibility !== 'hidden' && style.display !== 'none';
        };
        const describe = (el) => {
            const rect = el.getBoundingClientRect();
            const cls = typeof el.className === 'string' ? el.className : '';
            let scope = 'global';
            if (el.closest('.context-view, .quick-input-widget, .monaco-menu-container')) {
                scope = 'overlay';
            } else if (el.closest('.interactive-session, .interactive-input-box, .interactive-input-part, .chat-widget, [class*="chat"]')) {
                scope = 'chat';
            }
            return {
                tag: el.tagName.toLowerCase(),
                role: clean(el.getAttribute('role')),
                aria: clean(el.getAttribute('aria-label')),
                title: clean(el.getAttribute('title')),
                placeholder: clean(el.getAttribute('placeholder')),
                text: clean(el.innerText || el.textContent, 220),
                class: clean(cls, 220),
                id: clean(el.id, 120),
                editable: el.getAttribute('contenteditable') || '',
                scope,
                x: rect.x + rect.width / 2,
                y: rect.y + rect.height / 2,
                width: rect.width,
                height: rect.height,
            };
        };

        const selector = [
            'button',
            'a',
            '.action-item',
            '.chat-input-container',
            '.interactive-input-part',
            '.interactive-input-box',
            '.monaco-editor',
            'input',
            'textarea',
            'select',
            '[role="button"]',
            '[role="menuitem"]',
            '[role="option"]',
            '[contenteditable="true"]',
            '.monaco-list-row',
            '.monaco-list-row.action',
            '.quick-input-list-entry',
            '.chat-input-picker-item',
            '.monaco-action-bar .action-item'
        ].join(',');

        const seen = new Set();
        const items = [];
        for (const el of document.querySelectorAll(selector)) {
            if (!visible(el)) continue;
            const desc = describe(el);
            const key = [desc.tag, desc.text, desc.aria, desc.title, Math.round(desc.x), Math.round(desc.y)].join('|');
            if (seen.has(key)) continue;
            seen.add(key);
            items.push(desc);
        }

        const roots = [...document.querySelectorAll('.interactive-session, .interactive-input-box, .interactive-input-part, .chat-widget, [class*="chat"], [id*="chat"]')]
            .filter(visible)
            .slice(0, 40)
            .map(describe);

        const active = document.activeElement && visible(document.activeElement)
            ? describe(document.activeElement)
            : null;

        return {
            url: location.href,
            title: document.title,
            active,
            roots,
            items: items.slice(0, 240),
        };
    }""")


async def _cdp_click_item(page, item: dict) -> bool:
    try:
        await page.mouse.click(item["x"], item["y"])
        return True
    except Exception:
        return False


def _pick_best_action(
    items: list[dict],
    *,
    include_any: tuple[str, ...] = (),
    include_all: tuple[str, ...] = (),
    exclude: tuple[str, ...] = (),
    scopes: tuple[str, ...] = ("chat", "overlay", "global"),
    class_hints: tuple[str, ...] = (),
) -> dict | None:
    best = None
    best_score = -1

    for item in items:
        if scopes and item.get("scope") not in scopes:
            continue

        blob = _element_blob(item)
        if exclude and any(token in blob for token in exclude):
            continue
        if include_all and not all(token in blob for token in include_all):
            continue

        matches_any = [token for token in include_any if token in blob]
        if include_any and not matches_any:
            continue

        score = 0
        score += 40 * len(include_all)
        score += 20 * len(matches_any)
        score += 8 * sum(1 for hint in class_hints if hint in _normalize_ui_text(item.get("class", "")))
        if item.get("tag") in ("button", "a"):
            score += 3
        if item.get("aria"):
            score += 2
        if item.get("text"):
            score += 1

        if scopes:
            try:
                score += 5 * (len(scopes) - scopes.index(item.get("scope")))
            except ValueError:
                pass

        if score > best_score:
            best = item
            best_score = score

    return best


def _is_model_picker_candidate(item: dict) -> bool:
    item_class = _normalize_ui_text(item.get("class", ""))
    blob = _element_blob(item)
    if item.get("scope") != "chat":
        return False
    if "chat-mode-picker-item" in item_class or "chat-session-target-picker-item" in item_class:
        return False
    return (
        "chat-input-picker-item" in item_class
        or "pick model" in blob
        or (" model " in f" {blob} " and "mode" not in blob and "session" not in blob)
    )


def _is_chat_input_candidate(item: dict) -> bool:
    if item.get("scope") != "chat":
        return False

    item_class = _normalize_ui_text(item.get("class", ""))
    if item.get("editable") == "true":
        return True
    if item.get("tag") in ("textarea", "input"):
        return True
    return any(token in item_class for token in (
        "interactive-input",
        "chat-input",
        "ime-text-area",
        "chat-input-container",
        "monaco-editor",
    ))


def _looks_like_chat_input_focus(info: dict) -> bool:
    tag = (info.get("tag") or "").lower()
    cls = _normalize_ui_text(info.get("cls") or info.get("className") or "")
    parent = _normalize_ui_text(info.get("parent") or info.get("parentClass") or "")
    aria = _normalize_ui_text(info.get("ariaLabel") or info.get("aria") or "")
    placeholder = _normalize_ui_text(info.get("placeholder") or "")
    editable = bool(info.get("editable"))
    focus_within = bool(info.get("focusWithin"))
    joined = " ".join((cls, parent, aria, placeholder))

    if focus_within and any(
        token in joined
        for token in (
            "chat-input-container",
            "interactive-input-box",
            "interactive-input-part",
            "chat-widget",
            "chat",
        )
    ):
        return True

    if tag not in ("textarea", "input") and not editable:
        return False

    if "ime-text-area" in cls:
        return True

    return any(
        token in joined
        for token in (
            "chat",
            "interactive",
            "copilot",
            "ask",
            "message",
            "chat-input-container",
            "interactive-input-box",
            "interactive-input-part",
        )
    )


def _looks_like_model_option(text: str) -> bool:
    norm = _normalize_ui_text(text)
    if not norm:
        return False
    if any(token in norm for token in ("other models", "more models", "browse models")):
        return False
    return bool(MODEL_TEXT_PATTERN.search(text) or re.search(r"\b\d+x\b", norm))


def _extract_model_entry(item: dict, source_menu: str, current_label: str) -> dict | None:
    raw_text = (item.get("text") or item.get("aria") or item.get("title") or "").strip()
    if not _looks_like_model_option(raw_text):
        return None

    parts = [part.strip(" |") for part in re.split(r"[\n|]+", raw_text) if part.strip()]
    label = next((part for part in parts if MODEL_TEXT_PATTERN.search(part)), parts[0] if parts else raw_text)
    multiplier_match = re.search(r"\b(\d+(?:\.\d+)?)x\b", raw_text, re.I)
    multiplier = float(multiplier_match.group(1)) if multiplier_match else None
    label_norm = _normalize_ui_text(label)
    current_norm = _normalize_ui_text(current_label)

    return {
        "id": _slugify_model_label(label),
        "label": label,
        "raw_text": raw_text,
        "multiplier": multiplier,
        "multiplier_label": f"{multiplier:g}x" if multiplier is not None else "",
        "source_menu": source_menu,
        "selected": bool(current_norm and (label_norm in current_norm or current_norm in label_norm)),
        "preferred": _matches_preferred_model(raw_text),
    }


def _build_model_catalog(entries: list[dict], current_label: str) -> dict:
    merged: dict[str, dict] = {}
    for entry in entries:
        if not entry:
            continue
        existing = merged.get(entry["id"])
        if not existing:
            merged[entry["id"]] = dict(entry)
            continue
        if existing.get("multiplier") is None and entry.get("multiplier") is not None:
            existing["multiplier"] = entry["multiplier"]
            existing["multiplier_label"] = entry["multiplier_label"]
        existing["selected"] = existing.get("selected", False) or entry.get("selected", False)
        existing["preferred"] = existing.get("preferred", False) or entry.get("preferred", False)

    models = list(merged.values())
    models.sort(
        key=lambda item: (
            0 if item.get("preferred") else 1,
            1 if item.get("multiplier") == 1 else 2 if item.get("multiplier") == 3 else 99,
            item.get("multiplier") if item.get("multiplier") is not None else 999,
            _normalize_ui_text(item.get("label", "")),
        )
    )

    groups = {"1x": [], "3x": [], "unknown": []}
    for item in models:
        if item.get("multiplier") == 1:
            groups["1x"].append(item["id"])
        elif item.get("multiplier") == 3:
            groups["3x"].append(item["id"])
        else:
            groups["unknown"].append(item["id"])

    preferred_model = next((item for item in models if item.get("preferred")), None)
    return {
        "discovered_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "current_label": current_label,
        "preferred_model_id": preferred_model["id"] if preferred_model else "",
        "ordered_ids": [item["id"] for item in models],
        "groups": groups,
        "models": models,
    }


def _resolve_model_reference(model_ref: str, models: list[dict]) -> dict | None:
    norm_ref = _normalize_ui_text(model_ref)
    slug_ref = _slugify_model_label(model_ref)

    preferred = next((item for item in models if item.get("preferred")), None)
    if preferred and (_matches_preferred_model(model_ref) or slug_ref == preferred["id"]):
        return preferred

    for item in models:
        if slug_ref == item.get("id"):
            return item

    for item in models:
        haystack = _normalize_ui_text(f"{item.get('label', '')} {item.get('raw_text', '')}")
        if norm_ref and norm_ref in haystack:
            return item

    return None


def get_model_pool() -> list[str]:
    catalog = load_model_catalog()
    ordered_ids = catalog.get("ordered_ids") if isinstance(catalog, dict) else None
    if ordered_ids:
        return ordered_ids
    return list(MODEL_POOL)


async def _cdp_read_selected_model_label(page) -> str:
    text = await page.evaluate(r"""() => {
        const selectors = [
            '.action-item.chat-input-picker-item:not(.chat-mode-picker-item):not(.chat-session-target-picker-item) .chat-input-picker-label',
            '.action-item.chat-input-picker-item:not(.chat-mode-picker-item):not(.chat-session-target-picker-item)',
            'a[aria-label^="Pick Model"]'
        ];
        const clean = (value) => (value || '').replace(/\s+/g, ' ').trim();
        for (const sel of selectors) {
            const el = document.querySelector(sel);
            if (!el) continue;
            const raw = clean(el.innerText || el.textContent || el.getAttribute('aria-label') || '');
            if (!raw) continue;
            return raw.replace(/^pick model\s*/i, '').trim();
        }
        return '';
    }""")
    return (text or "").strip()


