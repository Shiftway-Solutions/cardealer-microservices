def inspect_chat_dom() -> dict:
    if not is_cdp_available():
        payload = {"error": "cdp_unavailable", "captured_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S")}
        _write_json_file(CHAT_DOM_SNAPSHOT_FILE, payload)
        return payload

    try:
        import asyncio as _asyncio

        async def _inspect():
            playwright, browser, page = await _cdp_connect_workbench_page()
            try:
                if not page:
                    return {"error": "workbench_not_found"}
                snapshot = await _cdp_collect_dom_snapshot(page)
                snapshot["captured_at"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                snapshot["current_model_label"] = await _cdp_read_selected_model_label(page)
                snapshot["screenshot_path"] = await _cdp_capture_screenshot(
                    page,
                    "inspect-dom",
                    {"current_model_label": snapshot["current_model_label"]},
                )
                return snapshot
            finally:
                await _cdp_close(playwright, browser)

        snapshot = _asyncio.run(_inspect())
        _write_json_file(CHAT_DOM_SNAPSHOT_FILE, snapshot)
        return snapshot
    except Exception as e:
        payload = {
            "error": str(e),
            "captured_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        }
        _write_json_file(CHAT_DOM_SNAPSHOT_FILE, payload)
        return payload


async def _cdp_open_model_picker(page) -> bool:
    snapshot = await _cdp_collect_dom_snapshot(page)
    candidates = [item for item in snapshot.get("items", []) if _is_model_picker_candidate(item)]
    candidate = _pick_best_action(
        candidates,
        include_any=("pick model", "gpt", "claude", "gemini", "opus", "sonnet", "haiku"),
        scopes=("chat",),
        class_hints=("chat-input-picker-item",),
    )
    if candidate and await _cdp_click_item(page, candidate):
        try:
            import asyncio

            await asyncio.sleep(0.5)
            if await _cdp_collect_overlay_items(page):
                return True
        except Exception:
            pass

    fallback_selectors = [
        'a[aria-label^="Pick Model"]',
        '.action-item.chat-input-picker-item:not(.chat-mode-picker-item):not(.chat-session-target-picker-item)',
        '.action-item.chat-input-picker-item:not(.chat-mode-picker-item):not(.chat-session-target-picker-item) .action-label',
    ]
    for selector in fallback_selectors:
        try:
            element = await page.query_selector(selector)
            if not element:
                continue
            box = await element.bounding_box()
            if not box:
                continue
            await page.mouse.click(box["x"] + box["width"] / 2, box["y"] + box["height"] / 2)
            import asyncio

            await asyncio.sleep(0.5)
            if await _cdp_collect_overlay_items(page):
                return True
        except Exception:
            continue

    return False


async def _cdp_collect_overlay_items(page) -> list[dict]:
    return await page.evaluate(r"""() => {
        const clean = (value, limit = 220) => (value || '').replace(/\s+/g, ' ').trim().slice(0, limit);
        const selectors = [
            '.context-view .monaco-list-row',
            '.context-view [role="menuitemradio"]',
            '.context-view [role="menuitem"]',
            '.context-view [role="option"]',
            '.quick-input-widget .monaco-list-row',
            '.quick-input-widget [role="option"]',
            '.quick-input-widget .quick-input-list-entry',
            '.monaco-menu-container .action-item',
            '.monaco-menu .action-item'
        ];
        const seen = new Set();
        const items = [];
        for (const selector of selectors) {
            for (const el of document.querySelectorAll(selector)) {
                const container = el.closest('.context-view, .quick-input-widget, .monaco-menu-container, .monaco-menu');
                const rect = el.getBoundingClientRect();
                const containerRect = container ? container.getBoundingClientRect() : rect;
                const style = window.getComputedStyle(container || el);
                const visible = containerRect.width > 0 && containerRect.height > 0 && style.display !== 'none' && style.visibility !== 'hidden';
                if (!visible) continue;

                const text = clean(el.innerText || el.textContent || el.getAttribute('aria-label') || '');
                const aria = clean(el.getAttribute('aria-label'));
                const key = [selector, text, aria, Math.round(rect.x), Math.round(rect.y)].join('|');
                if (seen.has(key)) continue;
                seen.add(key);

                const width = rect.width || Math.max(1, containerRect.width);
                const height = rect.height || 22;
                items.push({
                    tag: el.tagName.toLowerCase(),
                    role: clean(el.getAttribute('role')),
                    aria,
                    title: clean(el.getAttribute('title')),
                    placeholder: clean(el.getAttribute('placeholder')),
                    text,
                    class: clean(typeof el.className === 'string' ? el.className : '', 220),
                    id: clean(el.id, 120),
                    editable: el.getAttribute('contenteditable') || '',
                    scope: 'overlay',
                    x: rect.x + width / 2,
                    y: rect.y + height / 2,
                    width,
                    height,
                });
            }
        }
        return items;
    }""")


def discover_available_models() -> dict:
    if not is_cdp_available():
        return load_model_catalog()

    try:
        vscode_focus()
        time.sleep(0.5)
        import asyncio as _asyncio

        async def _discover():
            import asyncio

            playwright, browser, page = await _cdp_connect_workbench_page()
            try:
                if not page:
                    return {}

                current_label = await _cdp_read_selected_model_label(page)
                catalog_entries = []
                screenshots = []
                screenshots.append(
                    await _cdp_capture_screenshot(
                        page,
                        "discover-models_before",
                        {"current_model_label": current_label},
                    )
                )
                if await _cdp_open_model_picker(page):
                    await asyncio.sleep(0.6)
                    screenshots.append(
                        await _cdp_capture_screenshot(
                            page,
                            "discover-models_root",
                            {"current_model_label": current_label},
                        )
                    )
                    root_items = await _cdp_collect_overlay_items(page)
                    for item in root_items:
                        entry = _extract_model_entry(item, "root", current_label)
                        if entry:
                            catalog_entries.append(entry)

                    other_models = _pick_best_action(
                        root_items,
                        include_any=("other models", "more models", "browse models"),
                        scopes=("overlay",),
                    )
                    if other_models and await _cdp_click_item(page, other_models):
                        await asyncio.sleep(0.6)
                        screenshots.append(
                            await _cdp_capture_screenshot(
                                page,
                                "discover-models_other-models",
                                {"current_model_label": current_label},
                            )
                        )
                        nested_items = await _cdp_collect_overlay_items(page)
                        for item in nested_items:
                            entry = _extract_model_entry(item, "other-models", current_label)
                            if entry:
                                catalog_entries.append(entry)
