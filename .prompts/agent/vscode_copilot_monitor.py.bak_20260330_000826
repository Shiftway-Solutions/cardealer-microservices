async def _cdp_get_current_chat_title(page) -> str:
    """Reads the current active chat conversation title from the Copilot Chat panel."""
    return await page.evaluate(r"""() => {
        // Primary: the dedicated chat-view-title-label span in the conversation nav bar
        for (const sel of [
            '.chat-view-title-label',
            '.chat-view-title-inner .chat-view-title-label',
            '#workbench\\.panel\\.chat .chat-view-title-label',
        ]) {
            const el = document.querySelector(sel);
            if (el) {
                const text = (el.innerText || el.textContent || '').replace(/\s+/g, ' ').trim();
                if (text && text.length > 1) return text;
            }
        }
        // Fallback: the aria-label of the 'Pick Agent Session' button contains the title
        const sessionBtn = document.querySelector(
            'a[aria-label].chat-view-title-label-container, a.action-label.chat-view-title-label-container'
        );
        if (sessionBtn) {
            const lbl = (sessionBtn.getAttribute('aria-label') || '').replace(/\s+/g, ' ').trim();
            if (lbl && lbl !== 'Pick Agent Session') return lbl;
        }
        // Fallback: LI with class chat-view-title-action-item has the title as aria-label
        const titleItem = document.querySelector('li.action-item.chat-view-title-action-item');
        if (titleItem) {
            const lbl = (titleItem.getAttribute('aria-label') || '').replace(/\s+/g, ' ').trim();
            if (lbl) return lbl;
        }
        return '';
    }""")


async def _cdp_get_chat_history(page) -> list:
    """
    Reads the chat history/conversation list from the Copilot Chat panel.
    Each item: {title, fullText, ariaLabel, selected, x, y, dataIndex}
    The ariaLabel follows the pattern:
      "Local session TITLE (Status), created DATE"
    """
    return await page.evaluate(r"""() => {
        const listSels = [
            '#workbench\\.panel\\.chat .monaco-list-row',
            '.chat-list-view .monaco-list-row',
            '.pane-body.chat-viewpane .monaco-list-row',
            '[aria-label*="history" i] .monaco-list-row',
        ];
        for (const sel of listSels) {
            const els = [...document.querySelectorAll(sel)];
            if (els.length === 0) continue;
            return els.slice(0, 50).map((el) => {
                const rect = el.getBoundingClientRect();
                const ariaLabel = (el.getAttribute('aria-label') || '').trim();
                // Extract title from ariaLabel: "Local session TITLE (Status), created DATE"
                const m = ariaLabel.match(/^(?:Local session\s+)?(.+?)\s*\((?:Completed|Failed|In Progress)[^)]*\)/);
                const title = m ? m[1].trim() : (el.innerText || '').replace(/\s+/g, ' ').trim().substring(0, 80);
                return {
                    title,
                    fullText: (el.innerText || '').replace(/\s+/g, ' ').trim(),
                    ariaLabel,
                    selected: el.getAttribute('aria-selected') === 'true',
                    dataIndex: el.getAttribute('data-index') || '',
                    x: rect.x + rect.width / 2,
                    y: rect.y + rect.height / 2,
                };
            });
        }
        return [];
    }""")


