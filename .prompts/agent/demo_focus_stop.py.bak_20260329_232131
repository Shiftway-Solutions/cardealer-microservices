"""
DEMO: Focus input + Send prompt + Stop response — 100% DOM/CDP puro

Pasos:
  1. Leer título actual del chat
  2. Encontrar el input del chat via DOM → focus() + screenshot
  3. Escribir un prompt via page.keyboard.insert_text → screenshot
  4. Enviar con Enter → screenshot (modelo generando)
  5. Esperar que aparezca el botón de stop (⏹)
  6. Click en stop button via DOM → screenshot
  7. Verificar que el modelo detuvo la generación → screenshot final
"""
import asyncio
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
import vscode_copilot_monitor as m

SS = str(Path(__file__).parent / "screenshots")


async def demo():
    pw, browser, page = await m._cdp_connect_workbench_page()
    try:
        print("\n" + "="*60)
        print("DEMO: Focus Input → Send Prompt → Stop Response")
        print("="*60)

        # ── PASO 1: Estado inicial ──────────────────────────────────
        title = await m._cdp_get_current_chat_title(page)
        print(f"\n[PASO 1] Chat actual: {title!r}")
        await page.screenshot(path=f"{SS}/focus_01_estado_inicial.png")
        print("  📸 focus_01_estado_inicial.png")

        # ── PASO 2: Encontrar y hacer focus en el input ──────────────
        input_info = await page.evaluate(r"""() => {
            // Candidatos en orden de preferencia
            const SELECTORS = [
                // Textarea directa (modo simple)
                'textarea[data-mprt]',
                // Área contenteditable del chat (Agent mode)
                '.interactive-input-part .monaco-editor .view-line',
                '.interactive-input-part .monaco-editor textarea',
                // Cualquier textarea dentro del chat
                '.chat-input-container textarea',
                '.interactive-input-box textarea',
                // Monaco editor contenteditable
                '.interactive-input-part [contenteditable="true"]',
                '.chat-input-container [contenteditable="true"]',
                // Fallback: cualquier textarea visible
                'textarea',
            ];

            for (const sel of SELECTORS) {
                const els = document.querySelectorAll(sel);
                for (const el of els) {
                    const r = el.getBoundingClientRect();
                    if (r.width === 0 || r.height === 0) continue;
                    const cls = (typeof el.className === 'string' ? el.className : '').toLowerCase();
                    // Excluir editores de código del workspace
                    if (cls.includes('view-line')) continue;
                    return {
                        tag: el.tagName.toLowerCase(),
                        cls: cls.substring(0, 80),
                        placeholder: el.getAttribute('placeholder') || '',
                        aria: el.getAttribute('aria-label') || '',
                        x: Math.round(r.x + r.width/2),
                        y: Math.round(r.y + r.height/2),
                        selector: sel,
                        width: Math.round(r.width),
                        height: Math.round(r.height),
                    };
                }
            }

            // Último recurso: buscar el container del chat input y hacer click centrado
            const container = document.querySelector(
                '.interactive-input-part, .chat-input-container, .interactive-input-box'
            );
            if (container) {
                const r = container.getBoundingClientRect();
                if (r.width > 0) {
                    return {
                        tag: 'container',
                        cls: (typeof container.className === 'string' ? container.className : '').substring(0, 80),
                        placeholder: '',
                        aria: container.getAttribute('aria-label') || '',
                        x: Math.round(r.x + r.width/2),
                        y: Math.round(r.y + r.height*0.5),
                        selector: 'container-fallback',
                        width: Math.round(r.width),
                        height: Math.round(r.height),
                    };
                }
            }
            return null;
        }""")

        if not input_info:
            print("  ❌ No se encontró el input del chat")
            return

        print(f"\n[PASO 2] Input encontrado:")
        print(f"  tag={input_info['tag']!r}  selector={input_info['selector']!r}")
        print(f"  aria={input_info['aria']!r}  placeholder={input_info['placeholder']!r}")
        print(f"  coords: x={input_info['x']}, y={input_info['y']}  {input_info['width']}x{input_info['height']}px")

        # Click para dar focus
        await page.mouse.click(input_info["x"], input_info["y"])
        await asyncio.sleep(0.4)

        # Verificar que el focus quedó en el chat input
        focused_info = await page.evaluate(r"""() => {
            const el = document.activeElement;
            if (!el) return {tag: 'none', cls: ''};
            const nearChat = el.closest(
                '.interactive-input-part, .chat-input-container, .interactive-input-box, .chat-widget'
            );
            return {
                tag: el.tagName.toLowerCase(),
                cls: (typeof el.className === 'string' ? el.className : '').substring(0, 80),
                aria: el.getAttribute('aria-label') || '',
                inChat: !!nearChat,
                editable: el.getAttribute('contenteditable') === 'true',
                isTextarea: el.tagName.toLowerCase() === 'textarea',
            };
        }""")

        focus_ok = focused_info.get("inChat") or focused_info.get("isTextarea") or focused_info.get("editable")
        print(f"\n  [FOCUS] activeElement: tag={focused_info['tag']!r}  inChat={focused_info['inChat']}  "
              f"editable={focused_info['editable']}  isTextarea={focused_info['isTextarea']}")
        print(f"  [FOCUS] ✅ Focus confirmado en chat input" if focus_ok else "  [FOCUS] ⚠️  Focus obtenido (puede ser válido para Monaco)")

        await page.screenshot(path=f"{SS}/focus_02_input_focused.png")
        print("  📸 focus_02_input_focused.png")

        # ── PASO 3: Escribir un prompt ───────────────────────────────
        PROMPT_TEXT = "Di exactamente: DEMO OK - generación iniciada"
        print(f"\n[PASO 3] Escribiendo prompt: {PROMPT_TEXT!r}")

        # Limpiar si hay texto previo y escribir
        await page.keyboard.press("Meta+A")
        await asyncio.sleep(0.1)
        await page.keyboard.press("Backspace")
        await asyncio.sleep(0.1)
        await page.keyboard.insert_text(PROMPT_TEXT)
        await asyncio.sleep(0.5)

        await page.screenshot(path=f"{SS}/focus_03_prompt_escrito.png")
        print("  📸 focus_03_prompt_escrito.png")

        # ── PASO 4: Enviar el prompt (Enter) ─────────────────────────
        print(f"\n[PASO 4] Enviando prompt con Enter (CDP keyboard)")
        await page.keyboard.press("Enter")
        await asyncio.sleep(1.5)  # Dar tiempo al modelo para empezar

        await page.screenshot(path=f"{SS}/focus_04_prompt_enviado.png")
        print("  📸 focus_04_prompt_enviado.png")

        # ── PASO 5: Buscar el botón STOP ─────────────────────────────
        print(f"\n[PASO 5] Buscando botón Stop Response...")

        STOP_SELECTORS = [
            'button[aria-label="Stop Response"]',
            'button[aria-label="Stop"]',
            'button[aria-label*="stop" i]',
            '.interactive-stop-button',
            '.chat-stop-button',
            'button.codicon-debug-stop',
            'button.codicon-stop-circle',
            'button[title*="Stop" i]',
            'a[aria-label*="Stop" i]',
            # El ⏹ botón en el input area (imagen del usuario)
            '.chat-input-toolbars button[class*="stop"]',
            '.interactive-input-part button[class*="stop"]',
            # Cualquier botón con codicon-stop en el chat panel
            '#workbench\\.panel\\.chat button[class*="stop"]',
            '#workbench\\.panel\\.chat button[class*="codicon-stop"]',
        ]

        stop_info = await page.evaluate("""(selectors) => {
            for (const sel of selectors) {
                try {
                    const els = document.querySelectorAll(sel);
                    for (const el of els) {
                        const r = el.getBoundingClientRect();
                        if (r.width === 0 || r.height === 0) continue;
                        return {
                            selector: sel,
                            aria: el.getAttribute('aria-label') || '',
                            title: el.getAttribute('title') || '',
                            cls: (typeof el.className === 'string' ? el.className : '').substring(0, 100),
                            x: Math.round(r.x + r.width/2),
                            y: Math.round(r.y + r.height/2),
                        };
                    }
                } catch(e) { continue; }
            }

            // Búsqueda amplia: cualquier botón con 'stop' en el aria o title dentro del chat
            const allBtns = document.querySelectorAll('button, a[role="button"]');
            for (const btn of allBtns) {
                const aria = (btn.getAttribute('aria-label') || '').toLowerCase();
                const title = (btn.getAttribute('title') || '').toLowerCase();
                const cls = (typeof btn.className === 'string' ? btn.className : '').toLowerCase();
                if (!aria.includes('stop') && !title.includes('stop') && !cls.includes('stop')) continue;
                const r = btn.getBoundingClientRect();
                if (r.width === 0 || r.height === 0) continue;
                // Solo en el chat panel (lado derecho, x > 800)
                if (r.x < 800) continue;
                return {
                    selector: 'broad-search',
                    aria: btn.getAttribute('aria-label') || '',
                    title: btn.getAttribute('title') || '',
                    cls: cls.substring(0, 100),
                    x: Math.round(r.x + r.width/2),
                    y: Math.round(r.y + r.height/2),
                };
            }
            return null;
        }""", STOP_SELECTORS)

        if stop_info:
            print(f"  ✅ Stop button encontrado:")
            print(f"     selector={stop_info['selector']!r}")
            print(f"     aria={stop_info['aria']!r}  title={stop_info['title']!r}")
            print(f"     cls={stop_info['cls']!r}")
            print(f"     coords: x={stop_info['x']}, y={stop_info['y']}")
        else:
            print("  ⚠️  Stop button no visible — puede que el modelo ya terminó o el prompt fue muy corto")
            print("       Intentando igual con selector directo...")

        await page.screenshot(path=f"{SS}/focus_05_stop_visible.png")
        print("  📸 focus_05_stop_visible.png")

        # ── PASO 6: Click en Stop ─────────────────────────────────────
        if stop_info:
            print(f"\n[PASO 6] Clickeando Stop button via page.mouse.click({stop_info['x']}, {stop_info['y']})")
            await page.mouse.click(stop_info["x"], stop_info["y"])
            await asyncio.sleep(1.0)

            await page.screenshot(path=f"{SS}/focus_06_stop_clicked.png")
            print("  📸 focus_06_stop_clicked.png")

            # Verificar que el stop button desapareció
            still_visible = await page.evaluate("""() => {
                const SELS = [
                    'button[aria-label="Stop Response"]',
                    'button[aria-label="Stop"]',
                    'button[aria-label*="stop" i]',
                    '.interactive-stop-button',
                    '.chat-stop-button',
                ];
                for (const sel of SELS) {
                    try {
                        const el = document.querySelector(sel);
                        if (!el) continue;
                        const r = el.getBoundingClientRect();
                        if (r.width > 0 && r.height > 0) return true;
                    } catch(e) {}
                }
                return false;
            }""")

            if not still_visible:
                print("\n  ✅ Stop button DESAPARECIÓ — generación detenida correctamente")
            else:
                print("\n  ⚠️  Stop button sigue visible — puede necesitar más tiempo")
        else:
            print("\n[PASO 6] Sin stop button — tomando screenshot del estado final")

        # ── PASO 7: Estado final ──────────────────────────────────────
        await asyncio.sleep(0.5)
        final_title = await m._cdp_get_current_chat_title(page)
        await page.screenshot(path=f"{SS}/focus_07_estado_final.png")
        print(f"\n[PASO 7] Título final: {final_title!r}")
        print("  📸 focus_07_estado_final.png")

        print("\n" + "="*60)
        print("✅ DEMO COMPLETO")
        print(f"   Input focus:  {'✅ DOM/CDP click en coords + keyboard.insert_text + Enter' }")
        print(f"   Stop button:  {'✅ Encontrado y clickeado via page.mouse.click' if stop_info else '⚠️  No visible (prompt muy corto)'}")
        print(f"   AppleScript:  NO")
        print("="*60 + "\n")

    finally:
        await m._cdp_close(pw, browser)


if __name__ == "__main__":
    asyncio.run(demo())
