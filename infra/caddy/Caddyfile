# ─────────────────────────────────────────────────────────────────────────────
# OKLA — Caddy Reverse Proxy (equivalente local del nginx ingress de K8s)
#
# Replica la arquitectura de producción:
#   Browser → HTTPS (okla.local) → Caddy → Frontend (Next.js) → Gateway → Microservices
#
# Dos modos:
#   1) HTTPS local: https://okla.local   (mkcert, dev diario)
#   2) HTTP:80      para cloudflared tunnel (dominio público temporal)
# ─────────────────────────────────────────────────────────────────────────────

# ── HTTPS — Desarrollo local con dominio seguro ─────────────────────────────
https://okla.local {
	tls /etc/caddy/certs/okla.local.pem /etc/caddy/certs/okla.local-key.pem

	# Seguridad headers (mismos que nginx ingress en producción)
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}

	# BFF routes: Next.js API routes que deben servirse desde el frontend, no el gateway
	handle /api/pricing* {
		reverse_proxy {$FRONTEND_UPSTREAM:host.docker.internal:3000}
	}

	# API → Gateway (BFF pattern: misma ruta que en producción)
	handle /api/* {
		reverse_proxy gateway:80
	}

	# Health check del proxy
	handle /proxy/health {
		respond "OK" 200
	}

	# Todo lo demás → Frontend (Next.js)
	# Cache-Control headers are managed by next.config.ts (no-cache in dev, immutable in prod)
	handle {
		reverse_proxy {$FRONTEND_UPSTREAM:host.docker.internal:3000}
	}
}

# ── HTTP → HTTPS redirect for okla.local (S41-B1 security fix) ─────────────
# Redirects http://okla.local to https://okla.local (OWASP A05: Security Misconfiguration)
# Note: generic :80 block below is retained for cloudflared tunnel (different Host header)
http://okla.local {
        redir https://okla.local{uri} permanent
}

# ── HTTP — Endpoint para cloudflared tunnel ──────────────────────────────────
:80 {
	# Mismas rutas, sin TLS (cloudflared provee HTTPS al exterior)
	# BFF routes: Next.js API routes que deben servirse desde el frontend, no el gateway
	handle /api/pricing* {
		reverse_proxy {$FRONTEND_UPSTREAM:host.docker.internal:3000}
	}

	handle /api/* {
		reverse_proxy gateway:80
	}

	handle /proxy/health {
		respond "OK" 200
	}

	# Cache-Control headers are managed by next.config.ts (no-cache in dev, immutable in prod)
	handle {
		reverse_proxy {$FRONTEND_UPSTREAM:host.docker.internal:3000}
	}
}
