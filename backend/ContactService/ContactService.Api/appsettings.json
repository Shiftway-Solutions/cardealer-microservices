{
  "$comment": "Development-only configuration. For Docker/Production, use appsettings.Docker.json with secrets injected via environment variables or Docker secrets.",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Service": {
    "Name": "ContactService",
    "Host": "localhost",
    "Port": "5007",
    "HealthCheckUrl": "http://localhost:5007/health"
  },
  "Consul": {
    "Address": "http://localhost:8500"
  },
  "OpenTelemetry": {
    "ServiceName": "ContactService",
    "OtlpEndpoint": "http://otel-collector:4318",
    "Tracing": {
      "Enabled": true,
      "SamplingRatio": 0.1,
      "RecordException": true,
      "InstrumentHttpClient": true,
      "InstrumentEfCore": true
    },
    "Metrics": {
      "Enabled": true
    },
    "Resources": {
      "service.namespace": "cardealer",
      "deployment.environment": "development",
      "service.version": "1.0.0"
    }
  }
}
