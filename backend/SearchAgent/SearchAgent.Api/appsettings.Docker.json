{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=searchagent;Username=postgres;Password=postgres",
    "Redis": "redis:6379"
  },
  "Jwt": {
    "_comment": "JWT Key injected via K8s env var Jwt__Key",
    "Key": "",
    "Issuer": "AuthService",
    "Audience": "AuthServiceClients"
  },
  "Claude": {
    "_comment": "API key injected via K8s env var Claude__ApiKey",
    "ApiKey": ""
  },
  "Cors": {
    "AllowedOrigins": ["http://frontend-web:3000"]
  },
  "Gateway": {
    "Url": "http://gateway:8080"
  },
  "Serilog": {
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ]
  },
  "Observability": {
    "Enabled": true,
    "Endpoint": "http://otel-collector:4317"
  },
  "ErrorService": {
    "Url": "http://errorservice:8080"
  },
  "RabbitMQ": {
    "_comment": "Credentials injected via K8s env vars.",
    "Host": "rabbitmq",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  }
}
