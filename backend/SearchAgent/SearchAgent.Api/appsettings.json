{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=searchagent;Username=postgres;Password=postgres",
    "Redis": ""
  },
  "Jwt": {
    "_comment": "All secrets injected via K8s env vars. ${VAR} does NOT work in .NET JSON.",
    "Key": "",
    "Issuer": "AuthService",
    "Audience": "AuthServiceClients"
  },
  "Claude": {
    "ApiKey": ""
  },
  "Cors": {
    "AllowedOrigins": ["https://okla.com.do", "https://www.okla.com.do"]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Observability": {
    "Enabled": true,
    "Endpoint": "http://otel-collector:4317"
  },
  "ErrorService": {
    "Url": "http://errorservice:8080"
  },
  "AuditService": {
    "Enabled": true
  },
  "RabbitMQ": {
    "_comment": "Host/credentials injected via K8s env vars.",
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "Database": {
    "AutoMigrate": false
  }
}
